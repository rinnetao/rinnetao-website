---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: Record<string, any>;
  noindex?: boolean;
}

const {
  title = '輪廻タヲ | Rinne Tao',
  description = 'AI音楽・イラスト・映像クリエイター「輪廻タヲ」の公式サイト。過去作品のアーカイブや活動のお知らせを掲載するほか、お仕事のご依頼・ご相談も受け付けています。サイト自体もAIで構築した、輪廻タヲの作品のひとつです。',
  ogImage = '/og-thumbnail.png',
  ogType = 'website',
  jsonLd,
  noindex = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="ja">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-T77H3X52WP"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-T77H3X52WP');
    </script>

    <meta name="google-site-verification" content="8AXpL9Ji9Tc3gHhqlPudulxg9Xm66kWrd6llpT9J768" />

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Shippori+Mincho:wght@300;400&family=Zen+Kaku+Gothic+New:wght@700&display=swap"
      rel="stylesheet"
    />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="輪廻タヲ | Rinne Tao" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageURL} />

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body class="bg-bg text-text-primary font-gothic antialiased">

    <!-- ナビゲーション -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-[#0a0d0b]/80 backdrop-blur-sm">
      <div class="max-w-6xl mx-auto px-5 md:px-8 py-4 md:py-5 flex items-center justify-between">
        <a href="/" class="shrink-0 whitespace-nowrap text-[11px] font-light tracking-[0.25em] text-text-muted hover:text-text-primary transition-colors duration-300">RINNE TAO'S WEB</a>

        <!-- デスクトップメニュー -->
        <ul class="hidden md:flex items-center gap-5 lg:gap-7 shrink-0 whitespace-nowrap text-[11px] font-light tracking-[0.25em] text-text-muted">
          <li><a href="/#about" class="hover:text-text-primary transition-colors duration-300">ABOUT</a></li>
          <li><a href="/character" class:list={['hover:text-text-primary transition-colors duration-300', currentPath.startsWith('/character') && 'text-text-primary']}>CHARACTER</a></li>
          <li><a href="/gallery" class:list={['hover:text-text-primary transition-colors duration-300', currentPath.startsWith('/gallery') && 'text-text-primary']}>GALLERY</a></li>
          <li><a href="/#video" class="hover:text-text-primary transition-colors duration-300">VIDEO</a></li>
          <li><a href="/#music" class="hover:text-text-primary transition-colors duration-300">MUSIC</a></li>
          <li><a href="/blog" class:list={['hover:text-text-primary transition-colors duration-300', currentPath.startsWith('/blog') && 'text-text-primary']}>BLOG</a></li>
          <li><a href="/commission" class="inline-block whitespace-nowrap px-4 py-[5px] bg-white text-[#1a1a1a] text-[11px] font-sans-jp font-bold tracking-[0.15em] rounded-sm hover:bg-white/85 transition-all duration-300">お仕事のご依頼はこちら</a></li>
        </ul>

        <!-- SNSアイコン＋ハンバーガー -->
        <div class="flex items-center gap-4 ml-4 shrink-0">
          <a href="https://x.com/TaoRInne" target="_blank" rel="noopener" aria-label="X" class="text-text-muted hover:text-text-primary transition-colors duration-300">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
          </a>
          <a href="https://www.youtube.com/@TaoRInne" target="_blank" rel="noopener" aria-label="YouTube" class="text-text-muted hover:text-text-primary transition-colors duration-300">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href="https://open.spotify.com/intl-ja/artist/6cgNohFINOQDxktASQzmQy" target="_blank" rel="noopener" aria-label="Spotify" class="text-text-muted hover:text-text-primary transition-colors duration-300">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.48.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
          </a>

          <!-- ハンバーガーボタン（モバイルのみ） -->
          <button id="menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="メニューを開く">
            <span class="menu-bar block w-5 h-px bg-text-muted/70 transition-all duration-300"></span>
            <span class="menu-bar block w-5 h-px bg-text-muted/70 transition-all duration-300"></span>
          </button>
        </div>
      </div>
    </nav>

    <!-- モバイルメニュー：全画面オーバーレイ -->
    <div id="mobile-menu" class="hidden md:hidden fixed inset-0 bg-[#0d110e]/[.97] z-[60] flex flex-col items-center justify-center gap-10">
      <button id="menu-close" class="absolute top-4 right-5 text-text-muted text-2xl font-light">×</button>
      <ul class="flex flex-col items-center gap-10 text-[13px] font-light tracking-[0.4em] text-text-muted">
        <li><a href="/#about" class="hover:text-text-primary transition-colors duration-300">ABOUT</a></li>
        <li><a href="/character" class="hover:text-text-primary transition-colors duration-300">CHARACTER</a></li>
        <li><a href="/gallery" class="hover:text-text-primary transition-colors duration-300">GALLERY</a></li>
        <li><a href="/#video" class="hover:text-text-primary transition-colors duration-300">VIDEO</a></li>
        <li><a href="/#music" class="hover:text-text-primary transition-colors duration-300">MUSIC</a></li>
        <li><a href="/blog" class="hover:text-text-primary transition-colors duration-300">BLOG</a></li>
        <li><a href="/commission" class="px-6 py-3 bg-white text-[#1a1a1a] text-[13px] font-sans-jp font-bold tracking-[0.15em] rounded-sm hover:bg-white/90 transition-all duration-300">お仕事のご依頼はこちら</a></li>
      </ul>
    </div>

    <script>
      const btn = document.getElementById('menu-btn');
      const close = document.getElementById('menu-close');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
      close?.addEventListener('click', () => menu?.classList.add('hidden'));
      menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu.classList.add('hidden')));
    </script>

    <slot />

    <!-- フッター -->
    <footer class="border-t border-accent-line py-10 mt-16 md:mt-32">
      <div class="max-w-5xl mx-auto px-5 md:px-8 flex items-center justify-center">
        <p class="text-text-faint text-[10px] font-light">© 2026 Rinne Tao. All Rights Reserved.</p>
      </div>
    </footer>

    <!-- ページトップへ戻る -->
    <button id="back-to-top" class="hidden fixed bottom-10 right-8 z-30 w-14 h-14 rounded-full bg-black/70 backdrop-blur-sm border border-white/10 items-center justify-center text-white/70 hover:text-white hover:bg-black/85 transition-all duration-300" aria-label="ページトップへ戻る">
      <svg width="18" height="18" viewBox="0 0 14 14" fill="none"><polyline points="2,9 7,4 12,9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <script>
      const backToTop = document.getElementById('back-to-top');
      function toggleBackToTop() {
        const show = window.scrollY > 400;
        backToTop?.classList.toggle('hidden', !show);
        backToTop?.classList.toggle('flex', show);
      }
      window.addEventListener('scroll', toggleBackToTop, { passive: true });
      toggleBackToTop();
      backToTop?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    </script>
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  html {
    scroll-behavior: smooth;
  }
  body {
    -webkit-font-smoothing: antialiased;
    touch-action: manipulation;
  }
  /* 英語：Cormorant Garamond — 極細・高コントラスト、ファッション誌的 */
  /* 日本語：Shippori Mincho — 木版印刷的な風格のある明朝体 */
  .font-mincho {
    font-family: 'Cormorant Garamond', 'Shippori Mincho', serif;
  }
  .font-gothic {
    font-family: 'Shippori Mincho', 'Cormorant Garamond', serif;
  }
  .font-sans-jp {
    font-family: 'Zen Kaku Gothic New', sans-serif;
  }
</style>
