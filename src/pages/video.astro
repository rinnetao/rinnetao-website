---
import Layout from '../layouts/Layout.astro';

const videos = [
  { id: 'ujpMwPWFooQ', title: '魔女なの花ちゃん' },
  { id: 'BzoCzRS3O7M', title: '狂宴' },
  { id: 'IVguUeSzanY', title: '羅針盤' },
  { id: '2B4xwbvZxTE', title: '深海' },
  { id: 'w5nOl6GVUq8', title: 'PARADOX' },
  { id: 'DstG8uTv8yY', title: 'ANGEL' },
];
---

<Layout title="VIDEO | 輪廻タヲ">
  <div class="pt-24 pb-16 min-h-screen">
    <div class="max-w-5xl mx-auto px-5 md:px-8 py-12 mb-6">
      <h1 class="font-mincho text-text-primary text-3xl font-light tracking-[0.3em]">Video</h1>
    </div>

    <!-- サムネイルスライダー（プレーヤーの上） -->
    <div class="relative max-w-5xl mx-auto mb-1">
      <button id="prev-btn" class="absolute left-0 top-1/2 -translate-y-1/2 z-10 w-10 h-full flex items-center justify-center text-text-faint hover:text-text-muted transition-colors bg-gradient-to-r from-[#0d110e] to-transparent text-xl" aria-label="前へ">‹</button>
      <div class="overflow-hidden mx-10">
        <div class="flex gap-1">
          {videos.map((v, i) => (
            <button
              data-id={v.id}
              class:list={[
                'thumb-btn flex-shrink-0 w-[calc(33.333%-3px)] md:w-[calc(16.666%-1px)] aspect-video relative overflow-hidden group',
                i === 0 ? 'ring-1 ring-text-muted/60' : 'opacity-40 hover:opacity-70 transition-opacity'
              ]}
              aria-label={v.title}
            >
              <img src={`https://img.youtube.com/vi/${v.id}/mqdefault.jpg`} alt={v.title} class="w-full h-full object-cover" />
            </button>
          ))}
        </div>
      </div>
      <button id="next-btn" class="absolute right-0 top-1/2 -translate-y-1/2 z-10 w-10 h-full flex items-center justify-center text-text-faint hover:text-text-muted transition-colors bg-gradient-to-l from-[#0d110e] to-transparent text-xl" aria-label="次へ">›</button>
    </div>

    <!-- メインプレーヤー -->
    <div class="max-w-5xl mx-auto px-5 md:px-8">
      <div class="aspect-video w-full md:max-w-[896px] mx-auto mt-3">
        <iframe
          id="player-iframe"
          src={`https://www.youtube.com/embed/${videos[0].id}?rel=0`}
          title={videos[0].title}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="w-full h-full"
        ></iframe>
      </div>
    </div>

    <div class="text-center mt-10">
      <a href="https://www.youtube.com/@TaoRInne" target="_blank" rel="noopener"
        class="text-text-faint text-[11px] tracking-[0.3em] font-light border-b border-text-faint/40 pb-px hover:text-text-muted transition-colors duration-300">
        YouTube チャンネルを見る
      </a>
    </div>
  </div>
</Layout>

<script>
  const iframe = document.getElementById('player-iframe') as HTMLIFrameElement;
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.thumb-btn');
  let current = 0;

  function select(index: number) {
    const btn = thumbs[index];
    if (!btn) return;
    iframe.src = `https://www.youtube.com/embed/${btn.dataset.id}?rel=0&autoplay=1`;
    thumbs.forEach((b, i) => {
      b.classList.toggle('ring-1', i === index);
      b.classList.toggle('ring-text-muted/60', i === index);
      b.classList.toggle('opacity-40', i !== index);
      b.classList.toggle('hover:opacity-70', i !== index);
    });
    current = index;
  }

  thumbs.forEach((btn, i) => btn.addEventListener('click', () => select(i)));
  document.getElementById('prev-btn')?.addEventListener('click', () => select((current - 1 + thumbs.length) % thumbs.length));
  document.getElementById('next-btn')?.addEventListener('click', () => select((current + 1) % thumbs.length));
</script>
