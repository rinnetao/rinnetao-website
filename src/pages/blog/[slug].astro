---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection('blog');
const relatedPosts = (post.data.relatedSlugs ?? [])
  .map(slug => allPosts.find(p => p.slug === slug))
  .filter((p): p is CollectionEntry<'blog'> => Boolean(p));

function formatDate(d: Date) {
  return d.toISOString().slice(0, 10).replace(/-/g, '.');
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  author: { '@type': 'Person', name: '輪廻タヲ' },
  ...(post.data.ogImage ? { image: new URL(post.data.ogImage, Astro.site).toString() } : {}),
};
---

<Layout
  title={`${post.data.title} | 輪廻タヲ BLOG`}
  description={post.data.description}
  ogImage={post.data.ogImage}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="pt-24 pb-16 px-5 md:px-8 min-h-screen">
    <div class="max-w-2xl mx-auto">

      <div class="py-12 mb-8">
        <p class="text-text-faint text-[10px] tracking-[0.2em] font-mono mb-4">
          {formatDate(post.data.date)}
        </p>
        <h1 class="font-mincho text-text-primary text-2xl md:text-3xl font-light tracking-[0.1em] leading-relaxed">
          {post.data.title}
        </h1>
        <p class="text-text-faint text-[11px] font-light tracking-wider mt-4">
          執筆: 輪廻タヲ ・ AIを活用した音楽・イラスト・映像作品を制作するコンテンツクリエイター
        </p>
      </div>

      <div class="blog-content text-text-muted text-[15px] font-light leading-[2]">
        <Content />
      </div>

      <div class="not-prose my-10 border border-accent-line px-6 py-8">
        <div class="flex items-center gap-4 mb-5">
          <img src="/icon.webp" alt="輪廻タヲ" class="w-16 h-16 md:w-20 md:h-20 object-cover rounded-sm shrink-0" />
          <div>
            <p class="font-mincho text-text-primary text-base font-light tracking-wider mb-1">輪廻タヲ / Rinne Tao</p>
            <p class="text-text-muted text-[13px] font-light leading-relaxed">
              AIを制作に活用するコンテンツクリエイター。音楽、イラスト、映像作品を中心に発信しています。
            </p>
          </div>
        </div>
        <p class="text-text-muted text-[13px] font-light leading-relaxed mb-4">
          最新作品やAIに関する考察はXで発信しています。
        </p>
        <a
          href="https://x.com/TaoRInne"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-6 py-[10px] bg-white !text-[#1a1a1a] !no-underline text-[11px] font-sans-jp font-bold tracking-[0.15em] hover:bg-white/85 transition-all duration-300"
        >
          @TaoRInne をフォローする
        </a>
      </div>

      {relatedPosts.length > 0 && (
        <div class="mt-10">
          <p class="text-text-faint text-[10px] tracking-[0.3em] font-light uppercase mb-4">関連記事</p>
          <div class="space-y-1">
            {relatedPosts.map(rp => (
              <a href={`/blog/${rp.slug}`} class="flex items-center gap-4 border-b border-accent-line py-4 hover:opacity-80 transition-opacity duration-300">
                {rp.data.ogImage && (
                  <img src={rp.data.ogImage} alt={rp.data.title} loading="lazy" class="w-16 h-16 md:w-20 md:h-20 object-cover shrink-0" />
                )}
                <div class="min-w-0">
                  <p class="text-text-faint text-[10px] tracking-[0.2em] font-mono mb-1">{formatDate(rp.data.date)}</p>
                  <p class="font-mincho text-text-primary text-[14px] font-light tracking-wider">{rp.data.title}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="mt-16 pt-8 border-t border-accent-line">
        <a href="/blog" class="text-text-faint text-[10px] tracking-[0.3em] font-light hover:text-text-muted transition-colors duration-300">← 記事一覧へ戻る</a>
      </div>

    </div>
  </article>
</Layout>

<style>
  .blog-content :global(h2) {
    font-family: 'Cormorant Garamond', 'Shippori Mincho', serif;
    color: theme('colors.text.primary');
    font-size: 1.15rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .blog-content :global(p) {
    margin-bottom: 1.5rem;
  }
  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }
  .blog-content :global(li) {
    margin-bottom: 0.5rem;
    list-style-position: outside;
  }
  .blog-content :global(a) {
    color: theme('colors.text.primary');
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .blog-content :global(strong) {
    color: theme('colors.text.primary');
    font-weight: 700;
  }
  .blog-content :global(img) {
    width: 100%;
    margin: 2rem 0;
  }
  .blog-content :global(video) {
    width: 100%;
    margin: 2rem 0;
  }
  .blog-content :global(blockquote) {
    margin: 2rem 0;
    padding: 1rem 1.5rem;
    border-left: 2px solid theme('colors.accent.line');
    background: rgba(255, 255, 255, 0.02);
  }
  .blog-content :global(blockquote p) {
    margin-bottom: 0.75rem;
  }
  .blog-content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }
  .blog-content :global(table) {
    display: block;
    overflow-x: auto;
    white-space: nowrap;
    margin: 2rem 0;
    border-collapse: collapse;
    font-size: 12px;
    scrollbar-width: thin;
    scrollbar-color: theme('colors.text.faint') transparent;
  }
  .blog-content :global(table::-webkit-scrollbar) {
    height: 6px;
  }
  .blog-content :global(table::-webkit-scrollbar-thumb) {
    background: theme('colors.text.faint');
    border-radius: 3px;
  }
  .blog-content :global(table::-webkit-scrollbar-track) {
    background: rgba(255, 255, 255, 0.04);
  }
  .blog-content :global(th),
  .blog-content :global(td) {
    padding: 0.6rem 1rem;
    border: 1px solid theme('colors.accent.line');
    text-align: left;
  }
  .blog-content :global(th) {
    color: theme('colors.text.primary');
    font-weight: 700;
    background: rgba(255, 255, 255, 0.03);
  }
</style>
