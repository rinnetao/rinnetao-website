---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(d: Date) {
  return d.toISOString().slice(0, 10).replace(/-/g, '.');
}
---

<Layout title="AI音楽・Sunoの実践ブログ | 輪廻タヲ" description="Sunoを使ったAI音楽制作、音質改善、ミックス・マスタリング、著作権、音楽業界の最新動向を、AI音楽アーティストの輪廻タヲが実体験と一次情報から解説します。">
  <div class="pt-24 pb-16 px-5 md:px-8 min-h-screen">
    <div class="max-w-3xl mx-auto">

      <div class="py-12 mb-8">
        <h1 class="font-mincho text-text-primary text-3xl font-light tracking-[0.3em]">AI音楽・Suno実践ブログ</h1>
      </div>

      {posts.length === 0 ? (
        <p class="text-text-faint text-[13px] font-light">まだ記事がありません。</p>
      ) : (
        <div class="space-y-1">
          {posts.map(post => (
            <a
              href={`/blog/${post.slug}`}
              class="flex items-center gap-4 border-b border-accent-line py-6 px-2 -mx-2 hover:bg-white/[0.02] transition-colors duration-300"
            >
              {post.data.ogImage && (
                <img
                  src={post.data.ogImage}
                  alt={post.data.title}
                  loading="lazy"
                  class="w-16 h-16 md:w-20 md:h-20 object-cover shrink-0"
                />
              )}
              <div class="min-w-0">
                <p class="text-text-faint text-[10px] tracking-[0.2em] font-mono mb-2">
                  {formatDate(post.data.date)}
                </p>
                <p class="font-mincho text-text-primary text-base font-light tracking-wider">{post.data.title}</p>
              </div>
            </a>
          ))}
        </div>
      )}

    </div>
  </div>
</Layout>
