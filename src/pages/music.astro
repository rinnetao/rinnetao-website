---
import Layout from '../layouts/Layout.astro';
---

<Layout title="MUSIC | 輪廻タヲ" description="輪廻タヲの音楽作品">
  <div class="pt-24 pb-16 px-6 min-h-screen">
    <div class="max-w-3xl mx-auto">

      <div class="py-16 border-b border-matcha-800 mb-12">
        <p class="text-crimson-500/70 text-xs tracking-[0.4em] uppercase mb-3">Works</p>
        <h1 class="font-mincho text-5xl text-parchment tracking-widest">MUSIC</h1>
      </div>

      <p class="text-parchment/60 text-sm leading-loose font-gothic mb-12">
        各配信プラットフォームで公開しています。
      </p>

      <!-- プラットフォームリンク -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-16">
        {[
          ['Spotify', '#'],
          ['Apple Music', '#'],
          ['YouTube Music', '#'],
          ['Amazon Music', '#'],
          ['LINE MUSIC', '#'],
          ['その他', '#'],
        ].map(([name, url]) => (
          <a
            href={url}
            target="_blank"
            rel="noopener"
            class="border border-matcha-700 p-4 text-center text-sm text-parchment/50 tracking-wider hover:border-crimson-700/60 hover:text-parchment/80 transition-all font-gothic"
          >
            {name}
          </a>
        ))}
      </div>

      <!-- M3作品 -->
      <div class="border border-matcha-800 p-6">
        <p class="text-crimson-500/70 text-xs tracking-[0.4em] uppercase mb-4">Featured</p>
        <div class="flex gap-6 items-start">
          <div class="w-20 h-20 bg-matcha-900 border border-matcha-700 shrink-0 flex items-center justify-center">
            <span class="text-parchment/10 text-xs font-mincho">TAO</span>
          </div>
          <div>
            <h2 class="font-mincho text-parchment text-xl mb-1">TAO</h2>
            <p class="text-parchment/40 text-xs font-gothic mb-3">輪廻回廊 / M3-2025秋</p>
            <p class="text-parchment/50 text-sm leading-loose font-gothic">
              M3-2025秋で頒布した作品集。「輪廻回廊」特設サイトにて詳細公開中。
            </p>
            <a
              href="https://blue677256.studio.site/"
              target="_blank"
              rel="noopener"
              class="inline-block mt-4 text-parchment/40 text-xs tracking-wider border-b border-parchment/20 pb-0.5 hover:text-parchment/70 hover:border-parchment/50 transition-all font-gothic"
            >
              特設サイトを見る →
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</Layout>
