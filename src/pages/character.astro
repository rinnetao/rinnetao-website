---
import Layout from '../layouts/Layout.astro';

const illustrations = [
  { file: 'guitar-bust' },
  { file: 'piano' },
  { file: 'fullbody-front' },
  { file: 'crosslegged' },
  { file: 'festival-snack' },
  { file: 'lying-down' },
  { file: 'guitar-peace' },
  { file: 'sitting-profile' },
  { file: 'first-take' },
  { file: 'fullbody-pose' },
  { file: 'fullbody-standing' },
  { file: 'fisheye-street' },
  { file: 'eye-closeup' },
  { file: 'gift-box' },
  { file: 'subway' },
  { file: 'okinawa' },
  { file: 'finger-frame' },
  { file: 'studio-booth' },
];

const videos = [
  { file: 'mv-okinawa', title: 'MV「沖縄」' },
  { file: 'mv-first', title: 'MV 第一弾' },
  { file: 'carbonara', title: 'カルボナーラを作ろう' },
  { file: 'cosmetic', title: 'コスメティック' },
  { file: 'watashi-wa-tao', title: '私はタヲ' },
  { file: 'hanabi-kaeri', title: '花火の帰り' },
];
---

<Layout
  title="CHARACTER | 輪廻タヲ"
  description="AIタレントエージェンシー「ParallaxAgency」所属、キャラクターIP「輪廻タヲ」のプロフィール・作品ギャラリー。"
  ogImage="/character-og.jpg"
>
  <div class="pt-24 pb-16 px-5 md:px-8 min-h-screen">
    <div class="max-w-3xl mx-auto">

      <!-- Hero -->
      <div class="grid md:grid-cols-2 gap-6 md:gap-10 items-center mb-16 md:mb-24">
        <div class="aspect-[3/4] overflow-hidden bg-[#1e1c18] rounded-sm">
          <img src="/character/main.webp" alt="輪廻タヲ" class="w-full h-full object-cover" />
        </div>
        <div class="space-y-4">
          <p class="text-[9px] font-light tracking-[0.5em] text-text-muted/80 uppercase font-mincho">Character IP</p>
          <h1 class="font-mincho text-3xl md:text-4xl font-light tracking-[0.15em] text-text-primary leading-relaxed">
            輪廻タヲ<br /><span class="text-sm text-text-muted/80 tracking-[0.2em]">Rinne Tao</span>
          </h1>
          <p class="text-text-muted text-[14px] font-light leading-[2]">
            AIが生み出した、新しい時代のクリエイター。<br />
            「輪廻」は生と死を巡る円環を、「タヲ（道）」はその先にある道筋を意味します。
          </p>
        </div>
      </div>

      <!-- CTA -->
      <div class="mb-16 md:mb-24 bg-[#131110] rounded-sm p-6 border border-white/[0.04] text-center">
        <p class="text-text-muted text-[14px] font-light leading-[2] mb-5">
          本キャラクター「輪廻タヲ」はプロモーションに関連するCM起用・コラボレーション・IP活用のご依頼を募集しています。<br />
          お問合せは、ParallaxAgency、もしくは下記フォームよりお問い合わせください。
        </p>
        <a href="/commission" class="inline-block px-6 py-3 bg-white text-[#1a1a1a] text-[12px] font-sans-jp font-bold tracking-[0.15em] rounded-sm hover:bg-white/85 transition-all duration-300">
          お問合せはこちら
        </a>
      </div>

      <!-- Agency -->
      <div class="mb-16 md:mb-24 bg-[#131110] rounded-sm p-6 border border-white/[0.04]">
        <p class="text-[9px] font-light tracking-[0.4em] text-text-muted/80 uppercase mb-3 font-mincho">Official Agency</p>
        <p class="text-text-primary text-[14px] font-light tracking-wider mb-4">ParallaxAgency（アニメキャラ部門）</p>
        <div class="aspect-video overflow-hidden bg-[#1e1c18] rounded-sm mb-4">
          <img src="/hero-12.webp" alt="ParallaxAgency所属のお知らせ" class="w-full h-full object-cover" />
        </div>
        <p class="text-text-muted text-[13px] md:text-[14px] font-light leading-[2] mb-4">
          AIタレント／AIキャラクターIPの権利保護・管理を主目的とするエージェンシー。なりすましや無断使用からIPを守るとともに、広告・映像・SNS企画等のご依頼を公式窓口として一元的に受け付けています。
        </p>
        <div class="flex flex-wrap gap-5 text-[11px] tracking-[0.15em] font-light">
          <a href="https://parallaxagency.company/" target="_blank" rel="noopener" class="underline underline-offset-2 decoration-text-faint/40 text-text-muted hover:text-text-primary transition-colors duration-300">ParallaxAgency 公式サイト</a>
          <a href="/news/parallax-agency" class="underline underline-offset-2 decoration-text-faint/40 text-text-muted hover:text-text-primary transition-colors duration-300">所属のお知らせ</a>
        </div>
      </div>

      <!-- Movie -->
      <div class="mb-16 md:mb-24">
        <div class="mb-6">
          <h2 class="font-mincho text-sm font-light tracking-[0.35em] text-text-primary">Movie</h2>
        </div>
        <div id="char-movie-grid" class="grid grid-cols-2 gap-3"></div>
      </div>

      <!-- Illustration -->
      <div>
        <div class="mb-6">
          <h2 class="font-mincho text-sm font-light tracking-[0.35em] text-text-primary">Illustration</h2>
        </div>
        <div id="char-illust-grid" class="grid grid-cols-2 md:grid-cols-3 gap-3"></div>
      </div>

    </div>
  </div>
</Layout>

<!-- Illustration Lightbox -->
<div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90" role="dialog" aria-modal="true">
  <div class="absolute top-[8%] left-1/2 -translate-x-1/2 bg-black/70 px-3 py-1.5 rounded-sm text-white/70 text-[12px] tracking-wider text-center whitespace-nowrap pointer-events-none">← 左右にスワイプ →</div>
  <button id="lb-prev" class="hidden md:flex absolute left-[16%] top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-white/10 border border-white/70 hover:bg-white/20 items-center justify-center text-white/70 hover:text-white transition-all" aria-label="前へ">
    <svg width="10" height="16" viewBox="0 0 10 16" fill="none"><polyline points="8,2 2,8 8,14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>
  <button id="lb-next" class="hidden md:flex absolute right-[16%] top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-white/10 border border-white/70 hover:bg-white/20 items-center justify-center text-white/70 hover:text-white transition-all" aria-label="次へ">
    <svg width="10" height="16" viewBox="0 0 10 16" fill="none"><polyline points="2,2 8,8 2,14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>
  <div id="lb-swipe-area" class="relative w-full h-full overflow-hidden touch-pan-y">
  <div id="lb-track" class="w-full h-full flex">
    <div class="w-full h-full shrink-0 flex items-center justify-center">
      <img id="lb-img-prev" src="" alt="" class="max-h-[90vh] max-w-[90vw] object-contain select-none pointer-events-none" />
    </div>
    <div class="w-full h-full shrink-0 flex items-center justify-center">
      <img id="lb-img" src="" alt="" class="max-h-[90vh] max-w-[90vw] object-contain select-none" />
    </div>
    <div class="w-full h-full shrink-0 flex items-center justify-center">
      <img id="lb-img-next" src="" alt="" class="max-h-[90vh] max-w-[90vw] object-contain select-none pointer-events-none" />
    </div>
  </div>
  </div>
  <div class="absolute bottom-[10%] left-1/2 -translate-x-1/2 bg-black/70 px-3 py-1.5 rounded-sm text-white/70 text-[12px] tracking-wider text-center whitespace-nowrap pointer-events-none">画像をタップで閉じます</div>
</div>

<!-- Movie Lightbox -->
<div id="movie-lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90" role="dialog" aria-modal="true">
  <div class="absolute top-[8%] left-1/2 -translate-x-1/2 bg-black/70 px-3 py-1.5 rounded-sm text-white/70 text-[12px] tracking-wider text-center whitespace-nowrap pointer-events-none">← 左右にスワイプ →</div>
  <button id="mlb-prev" class="hidden md:flex absolute left-[16%] top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-white/10 border border-white/70 hover:bg-white/20 items-center justify-center text-white/70 hover:text-white transition-all" aria-label="前へ">
    <svg width="10" height="16" viewBox="0 0 10 16" fill="none"><polyline points="8,2 2,8 8,14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>
  <button id="mlb-next" class="hidden md:flex absolute right-[16%] top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-white/10 border border-white/70 hover:bg-white/20 items-center justify-center text-white/70 hover:text-white transition-all" aria-label="次へ">
    <svg width="10" height="16" viewBox="0 0 10 16" fill="none"><polyline points="2,2 8,8 2,14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>
  <div id="mlb-swipe-area" class="relative w-full h-full overflow-hidden touch-pan-y">
  <div id="mlb-track" class="w-full h-full flex">
    <div class="w-full h-full shrink-0 flex items-center justify-center">
      <video id="mlb-video-prev" class="max-h-[90vh] max-w-[90vw] pointer-events-none" muted playsinline preload="none"></video>
    </div>
    <div class="w-full h-full shrink-0 flex items-center justify-center">
      <video id="mlb-video" class="max-h-[90vh] max-w-[90vw]" controls playsinline preload="none"></video>
    </div>
    <div class="w-full h-full shrink-0 flex items-center justify-center">
      <video id="mlb-video-next" class="max-h-[90vh] max-w-[90vw] pointer-events-none" muted playsinline preload="none"></video>
    </div>
  </div>
  </div>
  <div class="absolute bottom-[10%] left-1/2 -translate-x-1/2 bg-black/70 px-3 py-1.5 rounded-sm text-white/70 text-[12px] tracking-wider text-center whitespace-nowrap pointer-events-none">外側をタップで閉じます</div>
  <div id="mlb-filename" class="absolute bottom-[5%] left-1/2 -translate-x-1/2 bg-black/70 px-2 py-1 rounded-sm text-white/40 text-[10px] font-mono tracking-wider"></div>
</div>

<script define:vars={{ illustrations, videos }}>
  function shuffleArr(arr) {
    const a = arr.slice();
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  // ===== Illustration：ランダム表示+ライトボックス =====
  const shuffledIllust = shuffleArr(illustrations);
  const illustGrid = document.getElementById('char-illust-grid');
  const ILLUST_TEASER = 6;

  function illustItemMarkup(w) {
    const btn = document.createElement('button');
    btn.className = 'group relative aspect-square overflow-hidden rounded-md bg-[#1e1c18] cursor-pointer';
    const img = document.createElement('img');
    img.src = `/character/${w.file}.webp`;
    img.alt = '';
    img.loading = 'lazy';
    img.className = 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-105';
    btn.appendChild(img);
    return btn;
  }

  shuffledIllust.slice(0, ILLUST_TEASER).forEach((w, i) => {
    const item = illustItemMarkup(w);
    item.addEventListener('click', () => openLightbox(i));
    illustGrid.appendChild(item);
  });

  const lb = document.getElementById('lightbox');
  const lbSwipeArea = document.getElementById('lb-swipe-area');
  const lbTrack = document.getElementById('lb-track');
  const lbImg = document.getElementById('lb-img');
  const lbImgPrev = document.getElementById('lb-img-prev');
  const lbImgNext = document.getElementById('lb-img-next');
  let lbIndex = 0;

  function illustSrcFor(idx) {
    const n = shuffledIllust.length;
    const w = shuffledIllust[((idx % n) + n) % n];
    return `/character/${w.file}.webp`;
  }

  function resetLbTrack(instant) {
    lbTrack.style.transition = instant ? 'none' : 'transform 250ms ease-out';
    lbTrack.style.transform = 'translateX(-100%)';
  }

  function showLb() {
    lbImg.src = illustSrcFor(lbIndex);
    lbImgPrev.src = illustSrcFor(lbIndex - 1);
    lbImgNext.src = illustSrcFor(lbIndex + 1);
    resetLbTrack(true);
  }

  function openLightbox(index) {
    lbIndex = index;
    showLb();
    lb.classList.remove('hidden');
    lb.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function lbGo(delta) {
    lbIndex += delta;
    showLb();
  }

  document.getElementById('lb-prev')?.addEventListener('click', () => lbGo(-1));
  document.getElementById('lb-next')?.addEventListener('click', () => lbGo(1));
  lb.addEventListener('click', e => { if (e.target === lb) closeLightbox(); });
  lbImg.addEventListener('click', closeLightbox);

  let lbDragging = false;
  let lbDragStartX = 0;
  let lbDragStartY = 0;
  let lbDragDeltaX = 0;
  let lbAreaWidth = 0;

  lbSwipeArea.addEventListener('touchstart', e => {
    lbDragging = true;
    lbDragStartX = e.touches[0].clientX;
    lbDragStartY = e.touches[0].clientY;
    lbDragDeltaX = 0;
    lbAreaWidth = lbSwipeArea.clientWidth;
    lbTrack.style.transition = 'none';
  }, { passive: true });

  lbSwipeArea.addEventListener('touchmove', e => {
    if (!lbDragging) return;
    const dx = e.touches[0].clientX - lbDragStartX;
    const dy = e.touches[0].clientY - lbDragStartY;
    if (Math.abs(dy) > Math.abs(dx)) return;
    lbDragDeltaX = dx;
    lbTrack.style.transform = `translateX(calc(-100% + ${dx}px))`;
  }, { passive: true });

  lbSwipeArea.addEventListener('touchend', () => {
    if (!lbDragging) return;
    lbDragging = false;
    const threshold = lbAreaWidth * 0.15;
    if (Math.abs(lbDragDeltaX) > threshold) {
      const dir = lbDragDeltaX < 0 ? 1 : -1;
      lbTrack.style.transition = 'transform 250ms ease-out';
      lbTrack.style.transform = `translateX(${dir < 0 ? '0%' : '-200%'})`;
      setTimeout(() => lbGo(dir), 250);
    } else {
      resetLbTrack(false);
    }
  }, { passive: true });

  // ===== Movie：ランダム表示+ライトボックス =====
  const shuffledVideos = shuffleArr(videos);
  const movieGrid = document.getElementById('char-movie-grid');
  const MOVIE_TEASER = 4;

  function movieItemMarkup(v) {
    const btn = document.createElement('button');
    btn.className = 'group relative aspect-square overflow-hidden rounded-md bg-[#1e1c18] cursor-pointer';
    const img = document.createElement('img');
    img.src = `/character/video/${v.file}.jpg`;
    img.alt = '';
    img.loading = 'lazy';
    img.className = 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-105';
    const playIcon = document.createElement('div');
    playIcon.className = 'absolute inset-0 flex items-center justify-center bg-black/10 group-hover:bg-black/30 transition-colors duration-300';
    playIcon.innerHTML = '<svg class="w-9 h-9 text-white opacity-90" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>';
    btn.appendChild(img);
    btn.appendChild(playIcon);
    return btn;
  }

  shuffledVideos.slice(0, MOVIE_TEASER).forEach((v, i) => {
    const item = movieItemMarkup(v);
    item.addEventListener('click', () => openMovieLightbox(i));
    movieGrid.appendChild(item);
  });

  const mlb = document.getElementById('movie-lightbox');
  const mlbSwipeArea = document.getElementById('mlb-swipe-area');
  const mlbTrack = document.getElementById('mlb-track');
  const mlbVideo = document.getElementById('mlb-video');
  const mlbVideoPrev = document.getElementById('mlb-video-prev');
  const mlbVideoNext = document.getElementById('mlb-video-next');
  const mlbFilename = document.getElementById('mlb-filename');
  let mlbIndex = 0;

  function videoFor(idx) {
    const n = shuffledVideos.length;
    return shuffledVideos[((idx % n) + n) % n];
  }

  function resetMlbTrack(instant) {
    mlbTrack.style.transition = instant ? 'none' : 'transform 250ms ease-out';
    mlbTrack.style.transform = 'translateX(-100%)';
  }

  function showMlb() {
    const cur = videoFor(mlbIndex);
    const prev = videoFor(mlbIndex - 1);
    const next = videoFor(mlbIndex + 1);

    mlbVideo.pause();
    mlbVideo.poster = `/character/video/${cur.file}.jpg`;
    mlbVideo.src = `/character/video/${cur.file}.mp4`;
    mlbFilename.textContent = cur.title;

    mlbVideoPrev.poster = `/character/video/${prev.file}.jpg`;
    mlbVideoPrev.removeAttribute('src');
    mlbVideoNext.poster = `/character/video/${next.file}.jpg`;
    mlbVideoNext.removeAttribute('src');

    resetMlbTrack(true);
  }

  function stopMlbPlayback() {
    mlbVideo.pause();
    mlbVideo.removeAttribute('src');
    mlbVideo.load();
  }

  function openMovieLightbox(index) {
    mlbIndex = index;
    showMlb();
    mlb.classList.remove('hidden');
    mlb.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeMovieLightbox() {
    stopMlbPlayback();
    mlb.classList.add('hidden');
    mlb.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function mlbGo(delta) {
    stopMlbPlayback();
    mlbIndex += delta;
    showMlb();
  }

  document.getElementById('mlb-prev')?.addEventListener('click', () => mlbGo(-1));
  document.getElementById('mlb-next')?.addEventListener('click', () => mlbGo(1));
  mlb.addEventListener('click', e => { if (e.target === mlb) closeMovieLightbox(); });

  let mlbDragging = false;
  let mlbDragStartX = 0;
  let mlbDragStartY = 0;
  let mlbDragDeltaX = 0;
  let mlbAreaWidth = 0;

  mlbSwipeArea.addEventListener('touchstart', e => {
    mlbDragging = true;
    mlbDragStartX = e.touches[0].clientX;
    mlbDragStartY = e.touches[0].clientY;
    mlbDragDeltaX = 0;
    mlbAreaWidth = mlbSwipeArea.clientWidth;
    mlbTrack.style.transition = 'none';
  }, { passive: true });

  mlbSwipeArea.addEventListener('touchmove', e => {
    if (!mlbDragging) return;
    const dx = e.touches[0].clientX - mlbDragStartX;
    const dy = e.touches[0].clientY - mlbDragStartY;
    if (Math.abs(dy) > Math.abs(dx)) return;
    mlbDragDeltaX = dx;
    mlbTrack.style.transform = `translateX(calc(-100% + ${dx}px))`;
  }, { passive: true });

  mlbSwipeArea.addEventListener('touchend', () => {
    if (!mlbDragging) return;
    mlbDragging = false;
    const threshold = mlbAreaWidth * 0.15;
    if (Math.abs(mlbDragDeltaX) > threshold) {
      const dir = mlbDragDeltaX < 0 ? 1 : -1;
      mlbTrack.style.transition = 'transform 250ms ease-out';
      mlbTrack.style.transform = `translateX(${dir < 0 ? '0%' : '-200%'})`;
      setTimeout(() => mlbGo(dir), 250);
    } else {
      resetMlbTrack(false);
    }
  }, { passive: true });

  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('hidden')) {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') lbGo(-1);
      if (e.key === 'ArrowRight') lbGo(1);
    }
    if (!mlb.classList.contains('hidden')) {
      if (e.key === 'Escape') closeMovieLightbox();
      if (e.key === 'ArrowLeft') mlbGo(-1);
      if (e.key === 'ArrowRight') mlbGo(1);
    }
  });
</script>
