---
import Layout from '../layouts/Layout.astro';

const highlights = [
  { file: 'guitar-bust' },
  { file: 'piano' },
  { file: 'fullbody-front' },
  { file: 'crosslegged' },
  { file: 'festival-snack' },
  { file: 'lying-down' },
  { file: 'guitar-peace' },
  { file: 'sitting-profile' },
];
---

<Layout
  title="CHARACTER | 輪廻タヲ"
  description="AIタレントエージェンシー「ParallaxAgency」所属、キャラクターIP「輪廻タヲ」のプロフィール・作品ギャラリー。"
  ogImage="/character-og.jpg"
>
  <div class="pt-24 pb-16 px-5 md:px-8 min-h-screen">
    <div class="max-w-3xl mx-auto">

      <!-- Hero -->
      <div class="grid md:grid-cols-2 gap-6 md:gap-10 items-center mb-16 md:mb-24">
        <div class="aspect-[3/4] overflow-hidden bg-[#1e1c18] rounded-sm">
          <img src="/character/main.webp" alt="輪廻タヲ" class="w-full h-full object-cover" />
        </div>
        <div class="space-y-4">
          <p class="text-[9px] font-light tracking-[0.5em] text-text-muted/80 uppercase font-mincho">Character IP</p>
          <h1 class="font-mincho text-3xl md:text-4xl font-light tracking-[0.15em] text-text-primary leading-relaxed">
            輪廻タヲ<br /><span class="text-sm text-text-muted/80 tracking-[0.2em]">Rinne Tao</span>
          </h1>
          <p class="text-text-muted text-[14px] font-light leading-[2]">
            AIが生み出した、新しい時代のクリエイター。<br />
            「輪廻」は生と死を巡る円環を、「タヲ（道）」はその先にある道筋を意味します。
          </p>
        </div>
      </div>

      <!-- CTA -->
      <div class="mb-16 md:mb-24 bg-[#131110] rounded-sm p-6 border border-white/[0.04] text-center">
        <p class="text-text-muted text-[14px] font-light leading-[2] mb-5">
          本キャラクター「輪廻タヲ」はプロモーションに関連するCM起用・コラボレーション・IP活用のご依頼を募集しています。<br />
          お問合せは、ParallaxAgency、もしくは下記フォームよりお問い合わせください。
        </p>
        <a href="/commission" class="inline-block px-6 py-3 bg-white text-[#1a1a1a] text-[12px] font-sans-jp font-bold tracking-[0.15em] rounded-sm hover:bg-white/85 transition-all duration-300">
          お問合せはこちら
        </a>
      </div>

      <!-- Agency -->
      <div class="mb-16 md:mb-24 bg-[#131110] rounded-sm p-6 border border-white/[0.04]">
        <p class="text-[9px] font-light tracking-[0.4em] text-text-muted/80 uppercase mb-3 font-mincho">Official Agency</p>
        <p class="text-text-primary text-[14px] font-light tracking-wider mb-4">ParallaxAgency（アニメキャラ部門）</p>
        <div class="aspect-video overflow-hidden bg-[#1e1c18] rounded-sm mb-4">
          <img src="/hero-12.webp" alt="ParallaxAgency所属のお知らせ" class="w-full h-full object-cover" />
        </div>
        <p class="text-text-muted text-[13px] md:text-[14px] font-light leading-[2] mb-4">
          AIタレント／AIキャラクターIPの権利保護・管理を主目的とするエージェンシー。なりすましや無断使用からIPを守るとともに、広告・映像・SNS企画等のご依頼を公式窓口として一元的に受け付けています。
        </p>
        <div class="flex flex-wrap gap-5 text-[11px] tracking-[0.15em] font-light">
          <a href="https://parallaxagency.company/" target="_blank" rel="noopener" class="underline underline-offset-2 decoration-text-faint/40 text-text-muted hover:text-text-primary transition-colors duration-300">ParallaxAgency 公式サイト</a>
          <a href="/news/parallax-agency" class="underline underline-offset-2 decoration-text-faint/40 text-text-muted hover:text-text-primary transition-colors duration-300">所属のお知らせ</a>
        </div>
      </div>

      <!-- Gallery highlights -->
      <div>
        <div class="mb-6">
          <h2 class="font-mincho text-sm font-light tracking-[0.35em] text-text-primary">Gallery</h2>
        </div>
        <div id="char-gallery-grid" class="grid grid-cols-2 md:grid-cols-4 gap-1">
          {highlights.map(({ file }) => (
            <div class="char-gallery-item aspect-[3/4] relative overflow-hidden bg-[#1e1c18] group cursor-pointer" data-src={`/character/${file}.webp`} data-file={file}>
              <img
                src={`/character/${file}.webp`}
                alt=""
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
              />
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</Layout>

<!-- Lightbox -->
<div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90" role="dialog" aria-modal="true">
  <button id="lb-prev" class="absolute left-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-white/10 border border-white/70 hover:bg-white/20 flex items-center justify-center text-white/70 hover:text-white transition-all" aria-label="前へ">
    <svg width="10" height="16" viewBox="0 0 10 16" fill="none"><polyline points="8,2 2,8 8,14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>
  <button id="lb-next" class="absolute right-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-white/10 border border-white/70 hover:bg-white/20 flex items-center justify-center text-white/70 hover:text-white transition-all" aria-label="次へ">
    <svg width="10" height="16" viewBox="0 0 10 16" fill="none"><polyline points="2,2 8,8 2,14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>
  <div id="lb-swipe-area" class="relative w-full h-full overflow-hidden touch-pan-y">
  <div id="lb-track" class="w-full h-full flex">
    <div class="w-full h-full shrink-0 flex items-center justify-center">
      <img id="lb-img-prev" src="" alt="" class="max-h-[90vh] max-w-[90vw] object-contain select-none pointer-events-none" />
    </div>
    <div class="w-full h-full shrink-0 flex items-center justify-center">
      <img id="lb-img" src="" alt="" class="max-h-[90vh] max-w-[90vw] object-contain select-none" />
    </div>
    <div class="w-full h-full shrink-0 flex items-center justify-center">
      <img id="lb-img-next" src="" alt="" class="max-h-[90vh] max-w-[90vw] object-contain select-none pointer-events-none" />
    </div>
  </div>
  </div>
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 text-white/70 text-[12px] tracking-wider text-center whitespace-nowrap pointer-events-none">画像をタップで一覧に戻ります</div>
  <div id="lb-filename" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/40 text-[10px] font-mono tracking-wider"></div>
</div>

<script>
  const items = Array.from(document.querySelectorAll('.char-gallery-item'));

  const lb = document.getElementById('lightbox')!;
  const lbSwipeArea = document.getElementById('lb-swipe-area')!;
  const lbTrack = document.getElementById('lb-track') as HTMLElement;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  const lbImgPrev = document.getElementById('lb-img-prev') as HTMLImageElement;
  const lbImgNext = document.getElementById('lb-img-next') as HTMLImageElement;
  const lbFilename = document.getElementById('lb-filename')!;
  let lbIndex = 0;

  function neighborSrc(offset: number) {
    if (items.length === 0) return '';
    const idx = (lbIndex + offset + items.length) % items.length;
    return (items[idx] as HTMLElement)?.dataset.src ?? '';
  }

  function resetTrack(instant: boolean) {
    lbTrack.style.transition = instant ? 'none' : 'transform 250ms ease-out';
    lbTrack.style.transform = 'translateX(-100%)';
  }

  function openLightbox(clickedEl: HTMLElement) {
    lbIndex = items.indexOf(clickedEl);
    showLb(clickedEl);
    lb.classList.remove('hidden');
    lb.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function showLb(el: HTMLElement) {
    lbImg.src = el.dataset.src ?? '';
    lbFilename.textContent = el.dataset.file ?? '';
    lbImgPrev.src = neighborSrc(-1);
    lbImgNext.src = neighborSrc(1);
    resetTrack(true);
  }

  function closeLightbox() {
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function lbGo(delta: number) {
    lbIndex = (lbIndex + delta + items.length) % items.length;
    showLb(items[lbIndex] as HTMLElement);
  }

  items.forEach(el => el.addEventListener('click', () => openLightbox(el as HTMLElement)));
  document.getElementById('lb-prev')?.addEventListener('click', () => lbGo(-1));
  document.getElementById('lb-next')?.addEventListener('click', () => lbGo(1));
  lb.addEventListener('click', e => { if (e.target === lb) closeLightbox(); });
  lbImg.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', e => {
    if (lb.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') lbGo(-1);
    if (e.key === 'ArrowRight') lbGo(1);
  });

  // ===== ライトボックス スワイプ（指の動きに追従） =====
  let lbDragging = false;
  let lbDragStartX = 0;
  let lbDragStartY = 0;
  let lbDragDeltaX = 0;
  let lbAreaWidth = 0;

  lbSwipeArea.addEventListener('touchstart', (e: TouchEvent) => {
    lbDragging = true;
    lbDragStartX = e.touches[0].clientX;
    lbDragStartY = e.touches[0].clientY;
    lbDragDeltaX = 0;
    lbAreaWidth = lbSwipeArea.clientWidth;
    lbTrack.style.transition = 'none';
  }, { passive: true });

  lbSwipeArea.addEventListener('touchmove', (e: TouchEvent) => {
    if (!lbDragging) return;
    const dx = e.touches[0].clientX - lbDragStartX;
    const dy = e.touches[0].clientY - lbDragStartY;
    if (Math.abs(dy) > Math.abs(dx)) return;
    lbDragDeltaX = dx;
    lbTrack.style.transform = `translateX(calc(-100% + ${dx}px))`;
  }, { passive: true });

  lbSwipeArea.addEventListener('touchend', () => {
    if (!lbDragging) return;
    lbDragging = false;
    const threshold = lbAreaWidth * 0.15;
    if (Math.abs(lbDragDeltaX) > threshold) {
      const dir = lbDragDeltaX < 0 ? 1 : -1;
      lbTrack.style.transition = 'transform 250ms ease-out';
      lbTrack.style.transform = `translateX(${dir < 0 ? '0%' : '-200%'})`;
      setTimeout(() => lbGo(dir), 250);
    } else {
      resetTrack(false);
    }
  }, { passive: true });
</script>
