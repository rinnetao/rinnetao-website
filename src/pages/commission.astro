---
import Layout from '../layouts/Layout.astro';

const items = [
  {
    id: 'illust',
    title: 'イラスト制作',
    price: '3,300円 / 枚〜',
    desc: [
      'AIを使ったオリジナルイラストを制作します。',
      '配信用楽曲イラスト・フライヤー・宣伝用ポスター・デザインロゴなど、用途に合わせてご相談ください。',
      '文字入れにも対応しています。',
      '複雑な構図・商用利用・複数枚のご依頼は別途お見積もりします。',
    ],
  },
  {
    id: 'music',
    title: '音楽（楽曲制作）',
    price: '11,000円 / 曲〜',
    desc: [
      'AIを使ったオリジナル楽曲・BGMを制作します。',
      '歌詞をご提供いただいての制作にも対応しています。',
      'ミックス・マスタリングはDAWで対応するため、配信・商用利用に適した品質でお届けします。',
      '用途・尺・歌詞の有無・商用利用の有無により価格が変動します。',
      'まずはお気軽にご相談ください。',
    ],
  },
  {
    id: 'mastering',
    title: 'AI音楽のMixdown / Mastering',
    price: '5,500円 / 曲〜',
    catch: '生成したままの音源とは明らかに違う、高品質な音質をお届けします。',
    desc: [
      '配信・リリース用など、商用利用に適したプロレベルのミキシング・マスタリングを提供いたします。',
      'ステムをご用意いただける場合は依頼時にお送りください。',
      '2mixのみの場合はこちらでステムスプリットして対応いたします。',
    ],
  },
  {
    id: 'video',
    title: '動画・MV制作',
    price: '11,000円 / 分〜',
    desc: [
      'ショート動画・MV・プロモーション映像を制作します。',
      '素材（音源・画像）のご支給状況や、尺・演出の複雑さにより価格が変動します。',
    ],
  },
  {
    id: 'ip-ad',
    title: 'キャラクターIPの広告活用',
    price: '応相談',
    desc: [
      '輪廻タヲのIPキャラクターを使ったCM風コンテンツを制作します。',
      '商品・サービスのプロモーション映像として、SNSでの活用を想定した制作が得意です。',
      '二次利用・商用利用の条件は別途ご相談ください。',
    ],
    link: { href: '/character', label: 'キャラクターギャラリーはこちら' },
  },
  {
    id: 'website',
    title: 'Webサイト制作',
    price: '33,000円〜',
    desc: [
      'ポートフォリオサイト・プロモーションサイトなどを制作します。',
      'AIクリエイター・アーティスト向けのサイト構築を得意としています。',
      'ページ数・機能・デザインの複雑さにより価格が変動します。',
    ],
  },
  {
    id: 'other',
    title: 'その他のご依頼について',
    price: 'ご相談',
    desc: [
      '項目がない内容でも、柔軟に対応いたします。',
      'まずはお気軽にご相談ください☺️',
    ],
  },
];

const terms = [
  ['価格はすべて税込表示です。'],
  ['当方はインボイス制度の適格請求書発行事業者ではありません（免税事業者）。', 'ご了承の上でご依頼ください。'],
  ['制作物にはAI生成を使用した内容が含まれます。'],
  ['ご依頼の内容によってはお断りする場合があります。'],
  ['納期はご相談の上で決定します。'],
  ['お支払いは制作前に全額前払いをお願いしています（案件により応相談）。'],
  ['制作物の著作権は輪廻タヲに帰属します。', '依頼者には使用目的・範囲に応じた使用権を付与します。'],
  ['制作物のご使用の際は「制作：輪廻タヲ」のクレジット表記をお願いしています。', '表記が難しい場合はご相談ください。'],
];
---

<Layout title="COMMISSION | 輪廻タヲ" description="輪廻タヲへの依頼・料金について">
  <div class="pt-24 pb-16 px-5 md:px-8 min-h-screen">
    <div class="max-w-xl mx-auto">

      <div class="py-12 mb-12">
        <p class="text-text-faint text-[10px] tracking-[0.4em] mb-3 font-light">COMMISSION</p>
        <h1 class="font-mincho text-text-primary text-3xl font-light tracking-[0.3em]">各種ご依頼について</h1>
      </div>

      <p class="text-text-muted text-[13px] font-light leading-[2.2] mb-6">
        輪廻タヲへのご依頼はこちらのページをご確認の上、下記の問い合わせフォームよりお問い合わせください。
      </p>
      <a href="#contact-form" class="block text-center mb-10 px-5 py-3 bg-white text-[#1a1a1a] text-[11px] font-sans-jp font-bold tracking-[0.15em] hover:bg-white/85 transition-all duration-300">
        ご依頼・問い合わせフォームはこちら
      </a>

      <!-- 料金一覧（アコーディオン） -->
      <p class="text-text-faint text-[11px] font-light mb-4">※タップすると詳細が表示されます</p>
      <div class="mb-16">
        {items.map(({ id, title, price, catch: tagline, desc, link }) => (
          <details id={id} class="group border-b border-accent-line">
            <summary class="flex items-baseline justify-between gap-4 py-5 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
              <span class="font-mincho text-text-primary text-base font-light tracking-wider">{title}</span>
              <span class="flex items-center gap-3 shrink-0">
                <span class="text-text-primary text-sm font-light tracking-wide font-sans-jp font-bold">{price}</span>
                <svg class="w-2.5 h-2.5 text-text-faint transition-transform duration-300 group-open:rotate-180" viewBox="0 0 10 10" fill="none"><polyline points="1,3 5,7 9,3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </summary>
            <div class="pb-6">
              {tagline && (
                <p class="text-[#e8b84a] text-[12px] font-sans-jp font-bold leading-[1.8] mb-3">{tagline}</p>
              )}
              <div class="text-text-faint text-[12px] font-light leading-[2]">
                {desc.map(line => <p>{line}</p>)}
                {link && (
                  <p>
                    <a href={link.href} class="underline underline-offset-2 decoration-text-faint/40 text-text-muted hover:text-text-primary transition-colors duration-300">{link.label}</a>
                  </p>
                )}
              </div>
            </div>
          </details>
        ))}
      </div>

      <!-- 共通事項 -->
      <details id="terms" class="group border-l border-accent-red pl-5 mb-16 scroll-mt-[72px] md:scroll-mt-[86px]">
        <summary class="flex items-center justify-between gap-4 mb-3 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
          <span class="flex items-baseline gap-2">
            <span class="font-mincho text-text-primary text-sm font-light tracking-wider">共通事項</span>
            <span class="text-text-faint text-[10px] font-light">（タップで詳細を表示）</span>
          </span>
          <svg class="w-3 h-3 text-text-muted transition-transform duration-300 group-open:rotate-180" viewBox="0 0 10 10" fill="none"><polyline points="1,3 5,7 9,3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </summary>
        <ul class="space-y-3">
          {terms.map(sentences => (
            <li class="text-text-muted text-[12px] font-light leading-[2] pl-4 relative before:content-['—'] before:absolute before:left-0 before:text-text-faint/60">
              {sentences.map((s, i) => (
                <Fragment set:html={i < sentences.length - 1 ? `${s}<br />` : s} />
              ))}
            </li>
          ))}
        </ul>
      </details>

      <!-- 修正・リテイクについて -->
      <details id="retake" class="group border-l border-accent-red pl-5 mb-16 scroll-mt-[72px] md:scroll-mt-[86px]">
        <summary class="flex items-center justify-between gap-4 mb-3 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
          <span class="flex items-baseline gap-2">
            <span class="font-mincho text-text-primary text-sm font-light tracking-wider">修正・リテイクについて</span>
            <span class="text-text-faint text-[10px] font-light">（タップで詳細を表示）</span>
          </span>
          <svg class="w-3 h-3 text-text-muted transition-transform duration-300 group-open:rotate-180" viewBox="0 0 10 10" fill="none"><polyline points="1,3 5,7 9,3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </summary>
        <p class="text-text-muted text-[13px] font-light leading-[2.2]">
          各ご依頼につき、2回までの内容リテイクに対応します。<br /><br />
          制作は、丸投げで発注しても希望通りの作品ができるわけではありません。<br />
          制作時は、お互いが制作内容を相互理解し、求める世界観に向かって協力することを前提とします。<br />
          ギャラリーの中にイメージに近い作品がある場合は、事前にリファレンスとしてお伝えいただけると助かります。
        </p>
      </details>

      <div id="contact-form" class="scroll-mt-[72px] md:scroll-mt-[86px]">
        <h2 class="font-mincho text-text-primary text-sm font-light tracking-[0.35em] pb-3 mb-4 border-b border-white/15">依頼方法</h2>
        <p class="text-text-muted text-[13px] font-light leading-[2.2] mb-6">
          上記内容をご確認の上、<br />
          下記フォームよりお問い合わせください。
        </p>

        <form id="contact-form-el" class="space-y-4">
          <input type="hidden" name="access_key" value="b893875f-b41b-4bc0-926c-46c26cce4772" />
          <input type="hidden" name="subject" value="【輪廻タヲ】お問い合わせ" />
          <input type="text" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

          <div>
            <label class="block text-text-faint text-[10px] tracking-[0.2em] mb-2" for="cf-name">お名前<span class="text-accent-red">*</span></label>
            <input id="cf-name" name="name" type="text" required class="w-full bg-[#131110] border border-white/[0.1] text-text-primary text-[13px] px-4 py-3 focus:outline-none focus:border-white/30 transition-colors" />
          </div>
          <div>
            <label class="block text-text-faint text-[10px] tracking-[0.2em] mb-2" for="cf-email">メールアドレス<span class="text-accent-red">*</span></label>
            <input id="cf-email" name="email" type="email" required class="w-full bg-[#131110] border border-white/[0.1] text-text-primary text-[13px] px-4 py-3 focus:outline-none focus:border-white/30 transition-colors" />
          </div>
          <div>
            <label class="block text-text-faint text-[10px] tracking-[0.2em] mb-2" for="cf-category">ご希望の内容</label>
            <select id="cf-category" name="category" required class="w-full bg-[#131110] border border-white/[0.1] text-text-primary text-[13px] px-4 py-3 focus:outline-none focus:border-white/30 transition-colors">
              <option value="" selected disabled>ご希望内容を選択</option>
              {items.map(({ title }) => <option value={title}>{title}</option>)}
            </select>
          </div>
          <div>
            <label class="block text-text-faint text-[10px] tracking-[0.2em] mb-2" for="cf-message">ご依頼内容・ご要望<span class="text-accent-red">*</span></label>
            <textarea id="cf-message" name="message" rows="6" required class="w-full bg-[#131110] border border-white/[0.1] text-text-primary text-[13px] px-4 py-3 focus:outline-none focus:border-white/30 transition-colors resize-y"></textarea>
          </div>

          <div class="flex items-start gap-3 pt-2">
            <input id="cf-agree" name="agree" type="checkbox" required class="mt-1 shrink-0 w-4 h-4 accent-white bg-[#131110] border border-white/[0.2]" />
            <label for="cf-agree" class="text-text-muted text-[12px] font-light leading-[1.9]">
              <a href="#terms" class="underline underline-offset-2 decoration-text-faint/40 hover:text-text-primary transition-colors duration-300">「共通事項」</a><a href="#retake" class="underline underline-offset-2 decoration-text-faint/40 hover:text-text-primary transition-colors duration-300">「修正・リテイクについて」</a>の項目を確認、内容を了承しました。
            </label>
          </div>

          <button type="submit" class="block w-full text-center px-5 py-3 bg-white text-[#1a1a1a] text-[11px] font-sans-jp font-bold tracking-[0.15em] hover:bg-white/85 transition-all duration-300">
            送信する
          </button>
          <p id="cf-status" class="text-[12px] font-light text-center hidden"></p>
        </form>
      </div>

    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form-el') as HTMLFormElement | null;
  const status = document.getElementById('cf-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = '送信中…';
    status?.classList.add('hidden');

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: new FormData(form),
      });
      const json = await res.json();
      if (!json.success) throw new Error(json.message || 'send failed');

      form.reset();
      if (status) {
        status.textContent = 'お問い合わせありがとうございます。内容を確認の上、ご連絡いたします。';
        status.className = 'text-[12px] font-light text-center text-text-primary mt-2';
      }
    } catch (err) {
      if (status) {
        status.textContent = '送信に失敗しました。時間をおいて再度お試しいただくか、直接メールにてご連絡ください。';
        status.className = 'text-[12px] font-light text-center text-accent-red mt-2';
      }
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = '送信する';
    }
  });
</script>
