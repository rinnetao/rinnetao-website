---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const videos = [
  { id: 'ujpMwPWFooQ', title: '魔女なの花ちゃん' },
  { id: 'BzoCzRS3O7M', title: '狂宴' },
  { id: 'IVguUeSzanY', title: '羅針盤' },
  { id: '2B4xwbvZxTE', title: '深海' },
  { id: 'w5nOl6GVUq8', title: 'PARADOX' },
  { id: 'DstG8uTv8yY', title: 'ANGEL' },
];

const musicWorks = [
  { title: 'TAO',              albumId: '3kHWitbxjEn6GFShKa592G', type: 'Album',  cover: 'https://i.scdn.co/image/ab67616d0000b2736d76e1041a05f1117e48fff2' },
  { title: '魔女なの花ちゃん', albumId: '2xzeTRvl5R1UZvlRsw0RFo', type: 'Single', cover: 'https://i.scdn.co/image/ab67616d0000b273ce25c3d122f4b5080fe80e78' },
  { title: '狂宴',              albumId: '5u6BawfR7TPKeXduLqwO3f', type: 'Single', cover: 'https://i.scdn.co/image/ab67616d0000b273da587e7978e15ca82287b3a0' },
  { title: 'Me No Know AI',    albumId: '3qdWJyWCBwrfUf0j7JHpKh', type: 'Single', cover: 'https://i.scdn.co/image/ab67616d0000b2733f866d7609f9da053dd42c61' },
  { title: '羅針盤',            albumId: '1OJBV44Sw3zVTU4h9oxFgq', type: 'Single', cover: 'https://i.scdn.co/image/ab67616d0000b27301766aa8dbe78e7383897e2b' },
  { title: '深海',              albumId: '7pulq3cniEtBBu1VbkD4bn', type: 'Single', cover: 'https://i.scdn.co/image/ab67616d0000b273f001d820a7b7e3980d64ad55' },
  { title: 'PARADOX',          albumId: '0OjiuPjVXkbmKNUhGz6LXV', type: 'Single', cover: 'https://i.scdn.co/image/ab67616d0000b273166984343fc3f549e9d8b446' },
  { title: 'Latch☆かんきん',    albumId: '7hLub3512tprb8NIhV37sF', type: 'Single', cover: 'https://i.scdn.co/image/ab67616d0000b27312565f13ecb0ad207a2876c9' },
  { title: 'ANGEL',            albumId: '2mSTKDoge4u8q1THkiLRC8', type: 'Single', cover: 'https://i.scdn.co/image/ab67616d0000b27314bb7efc1b89978d6a3ff68c' },
];

function formatDate(d: Date) {
  return d.toISOString().slice(0, 10).replace(/-/g, '.');
}

const newsPosts = await getCollection('news');

const news = [
  { date: new Date('2026-07-05'), text: 'サイトを公開しました。' },
  ...newsPosts.map(p => ({ date: p.data.date, text: p.data.newsText, href: `/news/${p.slug}` })),
]
  .sort((a, b) => b.date.valueOf() - a.date.valueOf())
  .map(n => ({ ...n, date: formatDate(n.date) }));

const galleryCats = [
  { file: 'char_131',     label: 'Character',  cat: 'char' },
  { file: 'angel_80',     label: 'Angel',      cat: 'angel' },
  { file: 'chaos_65',     label: 'Chaos',      cat: 'chaos' },
  { file: 'landscape_09', label: 'Landscape',  cat: 'landscape' },
  { file: 'jitsusya_20',  label: 'Photo',      cat: 'jitsusya' },
  { file: 'ipcd_16',      label: 'Commercial', cat: 'ipcd' },
];

// 直近のお知らせ用サムネイルはオープニング演出直後に見てもらえるよう先頭に配置。タップでニュース詳細へ
const heroImages = [
  { file: 'hero-12.webp', href: '/news/parallax-agency' },
  { file: 'hero-11.webp', href: '/news/tenrock-2026' },
  ...Array.from({ length: 10 }, (_, i) => ({ file: `hero-${i + 1}.webp` })),
];
const heroSlideTotal = heroImages.length;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: '輪廻タヲ',
  alternateName: 'Rinne Tao',
  url: 'https://rinnetao.com',
  image: 'https://rinnetao.com/icon.webp',
  jobTitle: 'AI Contents Creator',
  sameAs: [
    'https://x.com/TaoRInne',
    'https://www.youtube.com/@TaoRInne',
    'https://open.spotify.com/intl-ja/artist/6cgNohFINOQDxktASQzmQy',
    'https://music.apple.com/us/artist/rinne-tao/1863623820',
    'https://www.instagram.com/taorinne/',
    'https://www.tiktok.com/@rinnetao_ai',
    'https://note.com/rinnetao',
  ],
};
---

<Layout jsonLd={jsonLd}>

  <!-- ===== オープニング（初回訪問時のみ） ===== -->
  <div id="opening" class="fixed inset-0 z-[200] bg-black flex items-center justify-center cursor-pointer">
    <p id="opening-text" class="absolute text-text-primary font-mincho text-sm md:text-base tracking-[0.3em] opacity-0 text-center px-6" style="transition: opacity 900ms ease;">輪廻タヲの世界へ、ようこそ。</p>
    <img id="opening-logo" src="/opening-logo.webp" alt="輪廻タヲ" class="w-24 md:w-32 opacity-0" style="transition: opacity 900ms ease;" />
  </div>
  <script is:inline>
    (function () {
      var opening = document.getElementById('opening');
      if (!opening) return;
      if (localStorage.getItem('rt-intro-seen')) {
        opening.remove();
        return;
      }
      var text = document.getElementById('opening-text');
      var logo = document.getElementById('opening-logo');
      document.body.style.overflow = 'hidden';
      var done = false;
      function finish() {
        if (done) return;
        done = true;
        localStorage.setItem('rt-intro-seen', '1');
        opening.style.transition = 'opacity 800ms ease';
        opening.style.opacity = '0';
        setTimeout(function () {
          opening.remove();
          document.body.style.overflow = '';
        }, 800);
      }
      opening.addEventListener('click', finish);
      requestAnimationFrame(function () { text.style.opacity = '1'; });
      setTimeout(function () { text.style.opacity = '0'; }, 2200);
      setTimeout(function () { logo.style.opacity = '1'; }, 2800);
      setTimeout(finish, 6300);
    })();
  </script>

  <!-- ===== HERO：スライドショーのみ ===== -->
  <section class="pt-14 md:pt-24 md:mx-16 lg:mx-24">
    <div id="hero-swipe-area" class="relative aspect-video overflow-hidden touch-pan-y">
      <div id="hero-track" class="absolute inset-0 flex">
        {heroImages.map(({ file, href }, i) => (
          <div class="hero-slide w-full h-full shrink-0">
            {href ? (
              <a href={href} class="block w-full h-full">
                <img
                  src={`/${file}`}
                  alt=""
                  class="w-full h-full object-cover"
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
              </a>
            ) : (
              <img
                src={`/${file}`}
                alt=""
                class="w-full h-full object-cover"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            )}
          </div>
        ))}
      </div>
      <button id="hero-prev" class="absolute left-3 top-1/2 -translate-y-1/2 z-20 w-9 h-9 rounded-full bg-black/50 flex items-center justify-center text-white/80 hover:bg-black/70 hover:text-white transition-all duration-300" aria-label="前へ"><svg width="10" height="16" viewBox="0 0 10 16" fill="none"><polyline points="8,2 2,8 8,14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
      <button id="hero-next" class="absolute right-3 top-1/2 -translate-y-1/2 z-20 w-9 h-9 rounded-full bg-black/50 flex items-center justify-center text-white/80 hover:bg-black/70 hover:text-white transition-all duration-300" aria-label="次へ"><svg width="10" height="16" viewBox="0 0 10 16" fill="none"><polyline points="2,2 8,8 2,14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
      <div id="hero-dots" class="absolute bottom-4 left-0 right-0 z-20 flex justify-center gap-2">
        {Array.from({ length: heroSlideTotal }, (_, i) => i).map(i => (
          <button data-hero-dot={i}
            class:list={['hero-dot rounded-full h-px transition-all duration-500', i === 0 ? 'w-5 bg-white/60' : 'w-2 bg-white/20']}
            aria-label={`スライド ${i+1}`}
          ></button>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== コンテンツ ===== -->
  <div class="bg-[#1a1814] px-4 md:px-16 lg:px-24 py-12 md:py-20 space-y-16 md:space-y-24">

    <!-- NEWS -->
    <div id="news" class="scroll-mt-[72px] md:scroll-mt-[86px]">
      <h2 class="section-title">NEWS</h2>
      <div class="flex justify-end -mt-4 mb-4">
        <a href="/news" class="text-text-faint text-[10px] tracking-[0.2em] font-light hover:text-text-muted transition-colors duration-300">すべて見る →</a>
      </div>
      <ul class="space-y-3">
        {news.slice(0, 3).map(({ date, text, href }) => (
          <li>
            {href ? (
              <a href={href} class="w-full text-left flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-3 text-text-muted hover:text-text-primary transition-colors duration-300 group">
                <span class="text-[10px] tracking-[0.15em] font-mono text-text-faint shrink-0">{date}</span>
                <span class="text-[12px] md:text-[13px] font-light leading-[1.8] underline underline-offset-2 decoration-text-primary/60 group-hover:decoration-text-primary">{text}</span>
              </a>
            ) : (
              <div class="w-full flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-3 text-text-muted">
                <span class="text-[10px] tracking-[0.15em] font-mono text-text-faint shrink-0">{date}</span>
                <span class="text-[12px] md:text-[13px] font-light leading-[1.8]">{text}</span>
              </div>
            )}
          </li>
        ))}
      </ul>
    </div>

    <!-- About -->
    <div id="about" class="scroll-mt-[72px] md:scroll-mt-[86px] flex flex-col gap-5">
      <h2 class="section-title">About</h2>
      <div class="flex items-center gap-4">
        <a href="https://x.com/TaoRInne" target="_blank" rel="noopener" class="hover:opacity-70 transition-opacity duration-300 shrink-0">
          <img src="/icon.webp" alt="輪廻タヲ" class="w-12 h-12 rounded-full object-cover" />
        </a>
        <div>
          <p class="text-[9px] font-light tracking-[0.5em] text-text-muted/80 uppercase mb-1 font-mincho">AI Contents Creator</p>
          <h1 class="font-mincho text-lg font-light tracking-[0.25em] text-text-primary">
            輪廻タヲ <span class="text-xs text-text-muted/80 tracking-widest">/ Rinne Tao</span>
          </h1>
        </div>
      </div>
      <div class="space-y-3 text-text-muted text-[12px] md:text-[14px] font-light leading-[2] font-gothic">
        <p>AIを制作に活用するコンテンツクリエイターです。<br /><a href="https://x.com/TaoRInne" target="_blank" rel="noopener" class="underline underline-offset-2 decoration-text-faint/40 hover:text-text-primary transition-colors duration-300">X（@TaoRInne）</a>や<a href="https://www.youtube.com/@TaoRInne" target="_blank" rel="noopener" class="underline underline-offset-2 decoration-text-faint/40 hover:text-text-primary transition-colors duration-300">YouTube</a>を中心に、イラスト・音楽・映像作品をほぼ毎日発信しています。</p>
      </div>
      <div class="flex flex-wrap gap-5 border-t border-white/[0.04] pt-4">
        {[
          { label: 'X',           href: 'https://x.com/TaoRInne',                                          domain: 'x.com' },
          { label: 'YouTube',     href: 'https://www.youtube.com/@TaoRInne',                               domain: 'youtube.com' },
          { label: 'Spotify',     href: 'https://open.spotify.com/intl-ja/artist/6cgNohFINOQDxktASQzmQy', domain: 'spotify.com' },
          { label: 'Apple Music', href: 'https://music.apple.com/us/artist/rinne-tao/1863623820',          domain: 'music.apple.com' },
          { label: 'Suno',        href: 'https://suno.com/@taorinne',                                      domain: 'suno.com' },
          { label: 'TikTok',      href: 'https://www.tiktok.com/@rinnetao_ai',                             domain: 'tiktok.com' },
        ].map(({ label, href, domain }) => (
          <a href={href} target="_blank" rel="noopener"
            class="hover:opacity-70 transition-opacity duration-300"
            aria-label={label}>
            <img
              src={`https://www.google.com/s2/favicons?domain=${domain}&sz=32`}
              alt={label}
              class="w-5 h-5"
            />
          </a>
        ))}
      </div>
      <div class="border-t border-white/[0.04] pt-4">
        <a href="/character" class="block text-center px-5 py-3 bg-white text-[#1a1a1a] text-[11px] font-sans-jp font-bold tracking-[0.15em] hover:bg-white/85 transition-all duration-300">
          キャラクター「輪廻タヲ」の起用について
        </a>
      </div>
      <div class="border-t border-white/[0.04] pt-4">
        <p class="text-text-muted text-[12px] md:text-[14px] font-light leading-[2] font-gothic">
          輪廻タヲは、音楽 / イラスト / 動画 / Webサイト制作に関するご依頼を募集しています。<br />作品を見て、私の技術や世界観を自分のコンテンツに使ってみたい！という方は、ぜひ、フォームよりご連絡ください。
        </p>
        <a href="/commission" class="block text-center mt-4 px-5 py-3 bg-white text-[#1a1a1a] text-[11px] font-sans-jp font-bold tracking-[0.15em] hover:bg-white/85 transition-all duration-300">
          お問合せ・お仕事のご依頼はこちら
        </a>
      </div>
    </div>

    <!-- Gallery -->
    <div>
      <h2 class="section-title">Gallery</h2>
      <div class="flex justify-end -mt-4 mb-4">
        <a href="/gallery" class="text-text-faint text-[10px] tracking-[0.2em] font-light hover:text-text-muted transition-colors duration-300">すべて →</a>
      </div>
      <!-- モバイル：スワイプカルーセル -->
      <div class="md:hidden">
        <div id="gallery-swipe" class="relative overflow-hidden">
          <div id="gallery-track" class="flex gap-2">
            {galleryCats.map(({ file, label, cat }) => (
              <a href={`/gallery?cat=${cat}`} class="gallery-swipe-item shrink-0 w-[70%] aspect-[3/4] relative overflow-hidden bg-[#1e1c18] block rounded-sm">
                <img
                  src={`/gallery/${file}.webp`}
                  alt=""
                  loading="lazy"
                  class="w-full h-full object-cover"
                />
                <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 py-2 flex items-center justify-center bg-black/80">
                  <span class="text-white text-[12px] tracking-[0.2em] font-light font-mincho">{label}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
        <div id="gallery-dots" class="flex justify-center gap-1.5 mt-3">
          {galleryCats.map((_, i) => (
            <button data-gallery-dot={i}
              class:list={['gallery-dot rounded-full h-1.5 transition-all duration-300', i === 0 ? 'w-4 bg-text-muted/70' : 'w-1.5 bg-text-faint/40']}
              aria-label={`カテゴリ ${i + 1}`}
            ></button>
          ))}
        </div>
      </div>

      <!-- PC：グリッド -->
      <div class="hidden md:grid md:grid-cols-6 gap-1">
        {galleryCats.map(({ file, label, cat }) => (
          <a href={`/gallery?cat=${cat}`} class="aspect-[3/4] relative overflow-hidden bg-[#1e1c18] group cursor-pointer block">
            <img
              src={`/gallery/${file}.webp`}
              alt=""
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="flex absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-black/55 items-center justify-center">
              <span class="text-white text-[13px] tracking-[0.3em] font-light font-mincho drop-shadow-[0_1px_3px_rgba(0,0,0,0.8)]">{label}</span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Music -->
    <div id="music" class="scroll-mt-[72px] md:scroll-mt-[86px]">
      <h2 class="section-title">Music</h2>
      <div class="flex items-center gap-5 pb-4 mb-5 border-b border-white/[0.04]">
        <a href="https://open.spotify.com/intl-ja/artist/6cgNohFINOQDxktASQzmQy" target="_blank" rel="noopener" class="hover:opacity-70 transition-opacity duration-300" aria-label="Spotify">
          <img src="https://www.google.com/s2/favicons?domain=spotify.com&sz=32" alt="Spotify" class="w-5 h-5" />
        </a>
        <a href="https://music.apple.com/us/artist/rinne-tao/1863623820" target="_blank" rel="noopener" class="hover:opacity-70 transition-opacity duration-300" aria-label="Apple Music">
          <img src="https://www.google.com/s2/favicons?domain=music.apple.com&sz=32" alt="Apple Music" class="w-5 h-5" />
        </a>
        <p class="text-text-faint text-[10px] font-light tracking-[0.15em] font-gothic">各種ストリーミングで配信中 <br /> — <span class="text-text-muted">"RInne Tao"</span> で検索</p>
      </div>
      <div id="music-player-wrap" class="hidden mb-3">
        <iframe id="music-player-iframe"
          src=""
          width="100%"
          height="152"
          frameborder="0"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          class="rounded-sm"
        ></iframe>
      </div>
      {(['Album', 'Single'] as const).map(groupType => (
        <div class="mb-6 last:mb-0">
          <p class="text-text-faint text-[10px] tracking-[0.4em] uppercase font-mincho mb-3">{groupType}</p>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            {musicWorks.filter(w => w.type === groupType).map(({ title, albumId, cover }) => (
              <button data-album-id={albumId} data-title={title}
                class="music-thumb group relative aspect-square overflow-hidden rounded-md bg-[#1e1c18] cursor-pointer">
                <img src={cover} alt={title} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-colors duration-300 flex items-center justify-center">
                  <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                </div>
                <div class="absolute bottom-0 left-0 right-0 px-2 py-1.5 bg-gradient-to-t from-black/80 to-transparent">
                  <p class="text-white text-[10px] font-light tracking-wide truncate">{title}</p>
                </div>
              </button>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Video -->
    <div id="video" class="scroll-mt-[72px] md:scroll-mt-[86px]">
      <h2 class="section-title">Video</h2>
      <div class="relative mb-1">
        <button id="top-prev" class="absolute left-0 top-1/2 -translate-y-1/2 z-10 w-8 h-full flex items-center justify-center text-text-faint hover:text-text-muted transition-colors bg-gradient-to-r from-[#0e1210] to-transparent text-lg" aria-label="前へ">‹</button>
        <div id="top-thumb-scroll" class="relative overflow-hidden mx-8">
          <div id="top-thumb-track" class="flex gap-1">
            {videos.map((v, i) => (
              <button data-id={v.id}
                class:list={['top-thumb flex-shrink-0 w-[calc(30%-2px)] md:w-[calc(16.666%-1px)] aspect-video relative overflow-hidden',
                  i === 0 ? 'ring-1 ring-white/30' : 'opacity-40 hover:opacity-70 transition-opacity']}
                aria-label={v.title}>
                <img src={`https://img.youtube.com/vi/${v.id}/mqdefault.jpg`} alt={v.title} class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        </div>
        <button id="top-next" class="absolute right-0 top-1/2 -translate-y-1/2 z-10 w-8 h-full flex items-center justify-center text-text-faint hover:text-text-muted transition-colors bg-gradient-to-l from-[#0e1210] to-transparent text-lg" aria-label="次へ">›</button>
      </div>
      <div id="top-thumb-dots" class="flex md:hidden justify-center gap-1.5 mb-2">
        {videos.map((_, i) => (
          <span data-dot={i} class:list={['h-1 rounded-full transition-all duration-300', i === 0 ? 'w-4 bg-text-muted/70' : 'w-1 bg-text-faint/40']}></span>
        ))}
      </div>
      <div class="aspect-video w-full md:max-w-[896px] mx-auto mt-3">
        <iframe id="top-player-iframe"
          src={`https://www.youtube.com/embed/${videos[0].id}?rel=0`}
          title={videos[0].title}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen class="w-full h-full"></iframe>
      </div>
    </div>

    <!-- 依頼 -->
    <div>
      <h2 class="font-mincho text-sm font-light tracking-[0.35em] text-text-primary pb-3 mb-4 border-b border-white/15">お仕事のご依頼について</h2>
      <p class="text-text-muted text-[12px] font-light leading-[2] font-gothic mb-5">
        輪廻タヲは、音楽 / イラスト / 動画 / Webサイト制作に関するご依頼を募集しています。<br />詳細はこちら。
      </p>
      <a href="/commission" class="block text-center px-5 py-3 bg-white text-[#1a1a1a] text-[11px] font-sans-jp font-bold tracking-[0.15em] hover:bg-white/85 transition-all duration-300">
        お問合せ・お仕事のご依頼はこちら
      </a>
    </div>

  </div>

</Layout>

<style>
  .section-title {
    font-family: 'Cormorant Garamond', 'Shippori Mincho', serif;
    color: theme('colors.text.primary');
    font-size: 24px;
    font-weight: 400;
    text-align: center;
    letter-spacing: 0.3em;
    position: relative;
    margin-bottom: 32px;
  }
  .section-title::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -16px;
    transform: translateX(-50%);
    width: 44px;
    height: 3px;
    border-radius: 3px;
    background: theme('colors.text.primary');
  }
</style>

<script>
  // ===== Hero スライドショー =====
  const heroTrack = document.getElementById('hero-track') as HTMLElement;
  const heroSlideCount = document.querySelectorAll('.hero-slide').length;
  const heroDots = document.querySelectorAll<HTMLButtonElement>('.hero-dot');
  let heroIndex = 0;
  let heroTimer: ReturnType<typeof setInterval>;

  function renderTrack(instant = false) {
    heroTrack.style.transition = instant ? 'none' : 'transform 500ms ease-out';
    heroTrack.style.transform = `translateX(-${heroIndex * 100}%)`;
  }

  function goTo(rawIndex: number) {
    if (heroSlideCount === 0) return;
    const prevIndex = heroIndex;
    const newIndex = (rawIndex + heroSlideCount) % heroSlideCount;
    const isWrap = (prevIndex === heroSlideCount - 1 && newIndex === 0) || (prevIndex === 0 && newIndex === heroSlideCount - 1);
    heroDots[prevIndex]?.classList.remove('w-6', 'bg-text-muted/70');
    heroDots[prevIndex]?.classList.add('w-2', 'bg-text-faint/50');
    heroIndex = newIndex;
    heroDots[heroIndex]?.classList.remove('w-2', 'bg-text-faint/50');
    heroDots[heroIndex]?.classList.add('w-6', 'bg-text-muted/70');
    renderTrack(isWrap);
  }

  function startTimer() {
    heroTimer = setInterval(() => goTo(heroIndex + 1), 6000);
  }

  heroDots.forEach((dot, i) => {
    dot.addEventListener('click', () => { clearInterval(heroTimer); goTo(i); startTimer(); });
  });

  document.getElementById('hero-prev')?.addEventListener('click', () => { clearInterval(heroTimer); goTo(heroIndex - 1); startTimer(); });
  document.getElementById('hero-next')?.addEventListener('click', () => { clearInterval(heroTimer); goTo(heroIndex + 1); startTimer(); });

  startTimer();

  // ===== Hero スワイプ（指の動きに追従）=====
  const heroSwipeArea = document.getElementById('hero-swipe-area');
  let dragStartX = 0;
  let dragStartY = 0;
  let dragDeltaX = 0;
  let isDragging = false;
  let heroAreaWidth = 0;

  heroSwipeArea?.addEventListener('touchstart', (e) => {
    isDragging = true;
    dragStartX = e.touches[0].clientX;
    dragStartY = e.touches[0].clientY;
    dragDeltaX = 0;
    heroAreaWidth = heroSwipeArea.clientWidth;
    clearInterval(heroTimer);
    heroTrack.style.transition = 'none';
  }, { passive: true });

  heroSwipeArea?.addEventListener('touchmove', (e) => {
    if (!isDragging) return;
    const dx = e.touches[0].clientX - dragStartX;
    const dy = e.touches[0].clientY - dragStartY;
    if (Math.abs(dy) > Math.abs(dx)) return;
    e.preventDefault();
    const atStart = heroIndex === 0 && dx > 0;
    const atEnd = heroIndex === heroSlideCount - 1 && dx < 0;
    dragDeltaX = (atStart || atEnd) ? dx / 3 : dx;
    heroTrack.style.transform = `translateX(calc(-${heroIndex * 100}% + ${dragDeltaX}px))`;
  }, { passive: false });

  heroSwipeArea?.addEventListener('touchend', () => {
    if (!isDragging) return;
    isDragging = false;
    const threshold = heroAreaWidth * 0.15;
    if (Math.abs(dragDeltaX) > threshold) {
      goTo(heroIndex + (dragDeltaX < 0 ? 1 : -1));
    } else {
      renderTrack();
    }
    startTimer();
  }, { passive: true });

  // ===== Video スライダー（Heroと同じtranslateX方式：1マスずつ移動+無限ループ）=====
  const iframe = document.getElementById('top-player-iframe') as HTMLIFrameElement;
  const thumbViewport = document.getElementById('top-thumb-scroll') as HTMLElement;
  const thumbTrack = document.getElementById('top-thumb-track') as HTMLElement;
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.top-thumb');
  const thumbDots = document.querySelectorAll<HTMLSpanElement>('#top-thumb-dots [data-dot]');
  const videoCount = thumbs.length;
  let current = 0;

  function thumbStep() {
    return thumbs[0].getBoundingClientRect().width + 4; // gap-1 = 4px
  }
  function renderThumbTrack(instant = false, dragDeltaX = 0) {
    // PCなど全件が収まっている時はズラさない（元々全部見えているレイアウトを維持）
    const overflowing = thumbTrack.scrollWidth > thumbViewport.clientWidth + 20;
    const shiftIndex = overflowing ? current : 0;
    thumbTrack.style.transition = instant ? 'none' : 'transform 400ms ease-out';
    thumbTrack.style.transform = `translateX(${-shiftIndex * thumbStep() + dragDeltaX}px)`;
  }

  function select(index: number, instant = false) {
    const newIndex = (index + videoCount) % videoCount;
    const isWrap = (current === videoCount - 1 && newIndex === 0) || (current === 0 && newIndex === videoCount - 1);
    const btn = thumbs[newIndex];
    iframe.src = `https://www.youtube.com/embed/${btn.dataset.id}?rel=0&autoplay=1`;
    thumbs.forEach((b, i) => {
      b.classList.toggle('ring-1', i === newIndex);
      b.classList.toggle('ring-white/30', i === newIndex);
      b.classList.toggle('opacity-40', i !== newIndex);
    });
    thumbDots.forEach((d, i) => {
      d.classList.toggle('w-4', i === newIndex);
      d.classList.toggle('bg-text-muted/70', i === newIndex);
      d.classList.toggle('w-1', i !== newIndex);
      d.classList.toggle('bg-text-faint/40', i !== newIndex);
    });
    current = newIndex;
    renderThumbTrack(instant || isWrap);
  }

  thumbs.forEach((btn, i) => btn.addEventListener('click', () => select(i)));
  document.getElementById('top-prev')?.addEventListener('click', () => select(current - 1));
  document.getElementById('top-next')?.addEventListener('click', () => select(current + 1));
  renderThumbTrack(true);

  let thumbDragging = false;
  let thumbStartX = 0;
  let thumbStartY = 0;
  let thumbDragDeltaX = 0;

  thumbViewport?.addEventListener('touchstart', (e) => {
    thumbDragging = true;
    thumbStartX = e.touches[0].clientX;
    thumbStartY = e.touches[0].clientY;
    thumbDragDeltaX = 0;
  }, { passive: true });

  thumbViewport?.addEventListener('touchmove', (e) => {
    if (!thumbDragging) return;
    const dx = e.touches[0].clientX - thumbStartX;
    const dy = e.touches[0].clientY - thumbStartY;
    if (Math.abs(dy) > Math.abs(dx)) return;
    e.preventDefault();
    thumbDragDeltaX = dx;
    renderThumbTrack(true, thumbDragDeltaX);
  }, { passive: false });

  thumbViewport?.addEventListener('touchend', () => {
    if (!thumbDragging) return;
    thumbDragging = false;
    const threshold = thumbViewport.clientWidth * 0.1;
    if (Math.abs(thumbDragDeltaX) > threshold) {
      select(current + (thumbDragDeltaX < 0 ? 1 : -1));
    } else {
      renderThumbTrack();
    }
  }, { passive: true });

  // ===== Music：サムネイルタップでプレーヤー起動 =====
  const musicThumbs = document.querySelectorAll<HTMLButtonElement>('.music-thumb');
  const musicPlayerWrap = document.getElementById('music-player-wrap');
  const musicPlayerIframe = document.getElementById('music-player-iframe') as HTMLIFrameElement;

  musicThumbs.forEach(btn => {
    btn.addEventListener('click', () => {
      const albumId = btn.dataset.albumId;
      const title = btn.dataset.title ?? '';
      if (!albumId || !musicPlayerWrap || !musicPlayerIframe) return;
      musicPlayerIframe.src = `https://open.spotify.com/embed/album/${albumId}?utm_source=generator&theme=0&autoplay=1`;
      musicPlayerIframe.title = title;
      musicPlayerWrap.classList.remove('hidden');
      musicPlayerWrap.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  });

  // ===== Gallery スワイプ（Heroと同じtranslateX方式：1マスずつ移動+無限ループ）=====
  const galleryViewport = document.getElementById('gallery-swipe') as HTMLElement;
  const galleryTrack = document.getElementById('gallery-track') as HTMLElement;
  const galleryItems = document.querySelectorAll<HTMLElement>('.gallery-swipe-item');
  const galleryDots = document.querySelectorAll<HTMLButtonElement>('.gallery-dot');
  const galleryCount = galleryItems.length;
  let galleryIndex = 0;

  function galleryStep() {
    return galleryItems[0].getBoundingClientRect().width + 8; // gap-2 = 8px
  }
  function galleryCenterOffset() {
    return (galleryViewport.clientWidth - galleryItems[0].getBoundingClientRect().width) / 2;
  }
  function renderGalleryTrack(instant = false, dragDeltaX = 0) {
    galleryTrack.style.transition = instant ? 'none' : 'transform 400ms ease-out';
    const offset = galleryCenterOffset() - galleryIndex * galleryStep() + dragDeltaX;
    galleryTrack.style.transform = `translateX(${offset}px)`;
  }
  function setActiveGalleryDot(index: number) {
    galleryDots.forEach((d, i) => {
      d.classList.toggle('w-4', i === index);
      d.classList.toggle('bg-text-muted/70', i === index);
      d.classList.toggle('w-1.5', i !== index);
      d.classList.toggle('bg-text-faint/40', i !== index);
    });
  }
  function galleryGoTo(rawIndex: number) {
    const prevIndex = galleryIndex;
    const newIndex = (rawIndex + galleryCount) % galleryCount;
    const isWrap = (prevIndex === galleryCount - 1 && newIndex === 0) || (prevIndex === 0 && newIndex === galleryCount - 1);
    galleryIndex = newIndex;
    setActiveGalleryDot(galleryIndex);
    renderGalleryTrack(isWrap);
  }

  galleryDots.forEach((dot, i) => dot.addEventListener('click', () => galleryGoTo(i)));
  renderGalleryTrack(true);

  let galleryDragging = false;
  let galleryStartX = 0;
  let galleryStartY = 0;
  let galleryDragDeltaX = 0;

  galleryViewport?.addEventListener('touchstart', (e) => {
    galleryDragging = true;
    galleryStartX = e.touches[0].clientX;
    galleryStartY = e.touches[0].clientY;
    galleryDragDeltaX = 0;
  }, { passive: true });

  galleryViewport?.addEventListener('touchmove', (e) => {
    if (!galleryDragging) return;
    const dx = e.touches[0].clientX - galleryStartX;
    const dy = e.touches[0].clientY - galleryStartY;
    if (Math.abs(dy) > Math.abs(dx)) return;
    e.preventDefault();
    galleryDragDeltaX = dx;
    renderGalleryTrack(true, galleryDragDeltaX);
  }, { passive: false });

  galleryViewport?.addEventListener('touchend', () => {
    if (!galleryDragging) return;
    galleryDragging = false;
    const threshold = galleryViewport.clientWidth * 0.15;
    if (Math.abs(galleryDragDeltaX) > threshold) {
      galleryGoTo(galleryIndex + (galleryDragDeltaX < 0 ? 1 : -1));
    } else {
      renderGalleryTrack();
    }
  }, { passive: true });

  window.addEventListener('resize', () => {
    renderThumbTrack(true);
    renderGalleryTrack(true);
  });
</script>
