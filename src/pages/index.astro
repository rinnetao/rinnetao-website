---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const videos = [
  { id: 'ujpMwPWFooQ', title: '魔女なの花ちゃん' },
  { id: 'BzoCzRS3O7M', title: '狂宴' },
  { id: 'IVguUeSzanY', title: '羅針盤' },
  { id: '2B4xwbvZxTE', title: '深海' },
  { id: 'w5nOl6GVUq8', title: 'PARADOX' },
  { id: 'DstG8uTv8yY', title: 'ANGEL' },
];

function formatDate(d: Date) {
  return d.toISOString().slice(0, 10).replace(/-/g, '.');
}

const newsPosts = (await getCollection('news'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const news = [
  { date: formatDate(new Date('2026-07-05')), text: 'サイトを公開しました。' },
  ...newsPosts.map(p => ({ date: formatDate(p.data.date), text: p.data.newsText, href: `/news/${p.slug}` })),
];

// hero-11(天ロックのお知らせ用サムネイル)はオープニング演出直後に見てもらえるよう先頭に配置。タップでニュース詳細へ
const heroImages = [
  { file: 'hero-11.webp', href: '/news/tenrock-2026' },
  ...Array.from({ length: 10 }, (_, i) => ({ file: `hero-${i + 1}.webp` })),
];
const heroSlideTotal = heroImages.length;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: '輪廻タヲ',
  alternateName: 'Rinne Tao',
  url: 'https://rinnetao.com',
  image: 'https://rinnetao.com/icon.webp',
  jobTitle: 'AI Contents Creator',
  sameAs: [
    'https://x.com/TaoRInne',
    'https://www.youtube.com/@TaoRInne',
    'https://open.spotify.com/intl-ja/artist/6cgNohFINOQDxktASQzmQy',
    'https://music.apple.com/us/artist/rinne-tao/1863623820',
    'https://www.instagram.com/taorinne/',
    'https://www.tiktok.com/@rinnetao_ai',
    'https://note.com/rinnetao',
  ],
};
---

<Layout jsonLd={jsonLd}>

  <!-- ===== オープニング（初回訪問時のみ） ===== -->
  <div id="opening" class="fixed inset-0 z-[200] bg-black flex items-center justify-center cursor-pointer">
    <p id="opening-text" class="absolute text-text-primary font-mincho text-sm md:text-base tracking-[0.3em] opacity-0 text-center px-6" style="transition: opacity 900ms ease;">輪廻タヲの世界へ、ようこそ。</p>
    <img id="opening-logo" src="/opening-logo.webp" alt="輪廻タヲ" class="w-24 md:w-32 opacity-0" style="transition: opacity 900ms ease;" />
  </div>
  <script is:inline>
    (function () {
      var opening = document.getElementById('opening');
      if (!opening) return;
      if (localStorage.getItem('rt-intro-seen')) {
        opening.remove();
        return;
      }
      var text = document.getElementById('opening-text');
      var logo = document.getElementById('opening-logo');
      document.body.style.overflow = 'hidden';
      var done = false;
      function finish() {
        if (done) return;
        done = true;
        localStorage.setItem('rt-intro-seen', '1');
        opening.style.transition = 'opacity 800ms ease';
        opening.style.opacity = '0';
        setTimeout(function () {
          opening.remove();
          document.body.style.overflow = '';
        }, 800);
      }
      opening.addEventListener('click', finish);
      requestAnimationFrame(function () { text.style.opacity = '1'; });
      setTimeout(function () { text.style.opacity = '0'; }, 2200);
      setTimeout(function () { logo.style.opacity = '1'; }, 2800);
      setTimeout(finish, 6300);
    })();
  </script>

  <!-- ===== HERO：スライドショーのみ ===== -->
  <section class="pt-14 md:pt-24 md:mx-28">
    <div id="hero-swipe-area" class="relative aspect-video overflow-hidden touch-pan-y">
      <div id="hero-track" class="absolute inset-0 flex">
        {heroImages.map(({ file, href }, i) => (
          <div class="hero-slide w-full h-full shrink-0">
            {href ? (
              <a href={href} class="block w-full h-full">
                <img
                  src={`/${file}`}
                  alt=""
                  class="w-full h-full object-cover"
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
              </a>
            ) : (
              <img
                src={`/${file}`}
                alt=""
                class="w-full h-full object-cover"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            )}
          </div>
        ))}
      </div>
      <button id="hero-prev" class="absolute left-3 top-1/2 -translate-y-1/2 z-20 w-9 h-9 rounded-full bg-black/50 flex items-center justify-center text-white/80 hover:bg-black/70 hover:text-white transition-all duration-300" aria-label="前へ"><svg width="10" height="16" viewBox="0 0 10 16" fill="none"><polyline points="8,2 2,8 8,14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
      <button id="hero-next" class="absolute right-3 top-1/2 -translate-y-1/2 z-20 w-9 h-9 rounded-full bg-black/50 flex items-center justify-center text-white/80 hover:bg-black/70 hover:text-white transition-all duration-300" aria-label="次へ"><svg width="10" height="16" viewBox="0 0 10 16" fill="none"><polyline points="2,2 8,8 2,14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
      <div id="hero-dots" class="absolute bottom-4 left-0 right-0 z-20 flex justify-center gap-2">
        {Array.from({ length: heroSlideTotal }, (_, i) => i).map(i => (
          <button data-hero-dot={i}
            class:list={['hero-dot rounded-full h-px transition-all duration-500', i === 0 ? 'w-5 bg-white/60' : 'w-2 bg-white/20']}
            aria-label={`スライド ${i+1}`}
          ></button>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== コンテンツ ===== -->
  <div class="bg-[#1a1814] px-4 md:px-28 py-6 space-y-3">

    <!-- NEWS -->
    <div id="news" class="scroll-mt-[72px] md:scroll-mt-[86px] bg-[#131110] rounded-sm p-5 border border-white/[0.04]">
      <h2 class="font-mincho text-sm font-light tracking-[0.35em] text-text-primary pb-3 mb-4 border-b border-white/15">NEWS</h2>
      <ul class="space-y-3">
        {news.map(({ date, text, href }) => (
          <li>
            {href ? (
              <a href={href} class="w-full text-left flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-3 text-text-muted hover:text-text-primary transition-colors duration-300 group">
                <span class="text-[10px] tracking-[0.15em] font-mono text-text-faint shrink-0">{date}</span>
                <span class="text-[12px] md:text-[13px] font-light leading-[1.8] underline underline-offset-2 decoration-text-primary/60 group-hover:decoration-text-primary">{text}</span>
              </a>
            ) : (
              <div class="w-full flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-3 text-text-muted">
                <span class="text-[10px] tracking-[0.15em] font-mono text-text-faint shrink-0">{date}</span>
                <span class="text-[12px] md:text-[13px] font-light leading-[1.8]">{text}</span>
              </div>
            )}
          </li>
        ))}
      </ul>
    </div>

    <!-- 本サイトについて -->
    <div class="bg-[#131110] rounded-sm p-5 border border-white/[0.04]">
      <h2 class="font-mincho text-sm font-light tracking-[0.35em] text-text-primary pb-3 mb-4 border-b border-white/15">本サイトについて</h2>
      <p class="text-text-muted text-[12px] md:text-[14px] font-light leading-[2] font-gothic">
        輪廻タヲの公式ウェブサイト。<br />過去の制作物やイラストギャラリー、アナウンスを公開。
      </p>
      <p class="text-text-muted text-[12px] md:text-[14px] font-light leading-[2] font-gothic mt-4">
        輪廻タヲは、音楽 / イラスト / 動画 / Webサイト制作に関するご依頼を募集しています。<br />作品を見て、私の技術や世界観を自分のコンテンツに使ってみたい！という方は、ぜひ、フォームよりご連絡ください。
      </p>
      <a href="/commission" class="block text-center mt-4 px-5 py-3 bg-white text-[#1a1a1a] text-[11px] font-sans-jp font-bold tracking-[0.15em] hover:bg-white/85 transition-all duration-300">
        お問合せ・お仕事のご依頼はこちら
      </a>
    </div>

    <!-- About -->
    <div id="about" class="scroll-mt-[72px] md:scroll-mt-[86px] bg-[#131110] rounded-sm p-5 border border-white/[0.04] flex flex-col gap-5">
      <div class="flex items-center gap-4">
        <a href="https://x.com/TaoRInne" target="_blank" rel="noopener" class="hover:opacity-70 transition-opacity duration-300 shrink-0">
          <img src="/icon.webp" alt="輪廻タヲ" class="w-12 h-12 rounded-full object-cover" />
        </a>
        <div>
          <p class="text-[9px] font-light tracking-[0.5em] text-text-muted/80 uppercase mb-1 font-mincho">AI Contents Creator</p>
          <h1 class="font-mincho text-lg font-light tracking-[0.25em] text-text-primary">
            輪廻タヲ <span class="text-xs text-text-muted/80 tracking-widest">/ Rinne Tao</span>
          </h1>
        </div>
      </div>
      <div class="space-y-3 text-text-muted text-[12px] md:text-[14px] font-light leading-[2] font-gothic">
        <p>2025年10月活動開始。<br />AIを制作に活用するコンテンツクリエイターです。<br /><a href="https://x.com/TaoRInne" target="_blank" rel="noopener" class="underline underline-offset-2 decoration-text-faint/40 hover:text-text-primary transition-colors duration-300">X（@TaoRInne）</a>や<a href="https://www.youtube.com/@TaoRInne" target="_blank" rel="noopener" class="underline underline-offset-2 decoration-text-faint/40 hover:text-text-primary transition-colors duration-300">YouTube</a>を中心に、イラスト・音楽・映像作品をほぼ毎日発信しています。</p>
      </div>
      <div class="flex flex-wrap gap-5 border-t border-white/[0.04] pt-4">
        {[
          { label: 'X',           href: 'https://x.com/TaoRInne',                                          domain: 'x.com' },
          { label: 'YouTube',     href: 'https://www.youtube.com/@TaoRInne',                               domain: 'youtube.com' },
          { label: 'Spotify',     href: 'https://open.spotify.com/intl-ja/artist/6cgNohFINOQDxktASQzmQy', domain: 'spotify.com' },
          { label: 'Apple Music', href: 'https://music.apple.com/us/artist/rinne-tao/1863623820',          domain: 'music.apple.com' },
          { label: 'Instagram',   href: 'https://www.instagram.com/taorinne/',                             domain: 'instagram.com' },
          { label: 'TikTok',      href: 'https://www.tiktok.com/@rinnetao_ai',                             domain: 'tiktok.com' },
          { label: 'note',        href: 'https://note.com/rinnetao',                                       domain: 'note.com' },
        ].map(({ label, href, domain }) => (
          <a href={href} target="_blank" rel="noopener"
            class="hover:opacity-70 transition-opacity duration-300"
            aria-label={label}>
            <img
              src={`https://www.google.com/s2/favicons?domain=${domain}&sz=32`}
              alt={label}
              class="w-5 h-5"
            />
          </a>
        ))}
      </div>
    </div>

    <!-- Gallery -->
    <div class="bg-[#111210] rounded-sm p-5 border border-white/[0.04]">
      <div class="flex items-baseline justify-between mb-4">
        <h2 class="font-mincho text-sm font-light tracking-[0.35em] text-text-primary">Gallery</h2>
        <a href="/gallery" class="text-text-faint text-[10px] tracking-[0.2em] font-light hover:text-text-muted transition-colors duration-300">すべて →</a>
      </div>
      <div class="grid grid-cols-3 md:grid-cols-6 gap-1">
        {[
          { file: 'char_131',     label: 'Character',  cat: 'char' },
          { file: 'angel_80',     label: 'Angel',      cat: 'angel' },
          { file: 'chaos_65',     label: 'Chaos',      cat: 'chaos' },
          { file: 'landscape_09', label: 'Landscape',  cat: 'landscape' },
          { file: 'jitsusya_20',  label: 'Photo',      cat: 'jitsusya' },
          { file: 'ipcd_16',      label: 'Commercial', cat: 'ipcd' },
        ].map(({ file, label, cat }, i) => (
          <a href={`/gallery?cat=${cat}`} class="aspect-[3/4] relative overflow-hidden bg-[#1e1c18] group cursor-pointer block">
            <img
              src={`/gallery/${file}.webp`}
              alt={label}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <!-- 常時表示ラベル（スマホ：ホバーがないため） -->
            <div class:list={['md:hidden absolute inset-x-0 top-1/2 -translate-y-1/2 py-1.5 flex items-center justify-center',
              i % 2 === 0 ? 'bg-black/85' : 'bg-neutral-700/85']}>
              <span class="text-white text-[10px] tracking-[0.15em] font-light font-mincho">{label}</span>
            </div>
            <!-- ホバー時オーバーレイ（PC） -->
            <div class="hidden md:flex absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-black/55 items-center justify-center">
              <span class="text-white text-[13px] tracking-[0.3em] font-light font-mincho drop-shadow-[0_1px_3px_rgba(0,0,0,0.8)]">{label}</span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Video -->
    <div id="video" class="scroll-mt-[72px] md:scroll-mt-[86px] bg-[#0e1210] rounded-sm p-5 border border-white/[0.04]">
      <h2 class="font-mincho text-sm font-light tracking-[0.35em] text-text-primary mb-4">Video</h2>
      <div class="relative mb-1">
        <button id="top-prev" class="absolute left-0 top-1/2 -translate-y-1/2 z-10 w-8 h-full flex items-center justify-center text-text-faint hover:text-text-muted transition-colors bg-gradient-to-r from-[#0e1210] to-transparent text-lg" aria-label="前へ">‹</button>
        <div id="top-thumb-scroll" class="overflow-x-auto snap-x snap-mandatory scroll-smooth mx-8 [&::-webkit-scrollbar]:hidden" style="scrollbar-width: none; -ms-overflow-style: none;">
          <div class="flex gap-1">
            {videos.map((v, i) => (
              <button data-id={v.id}
                class:list={['top-thumb flex-shrink-0 snap-start w-[calc(30%-2px)] md:w-[calc(16.666%-1px)] aspect-video relative overflow-hidden',
                  i === 0 ? 'ring-1 ring-white/30' : 'opacity-40 hover:opacity-70 transition-opacity']}
                aria-label={v.title}>
                <img src={`https://img.youtube.com/vi/${v.id}/mqdefault.jpg`} alt={v.title} class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        </div>
        <button id="top-next" class="absolute right-0 top-1/2 -translate-y-1/2 z-10 w-8 h-full flex items-center justify-center text-text-faint hover:text-text-muted transition-colors bg-gradient-to-l from-[#0e1210] to-transparent text-lg" aria-label="次へ">›</button>
      </div>
      <div id="top-thumb-dots" class="flex md:hidden justify-center gap-1.5 mb-2">
        {videos.map((_, i) => (
          <span data-dot={i} class:list={['h-1 rounded-full transition-all duration-300', i === 0 ? 'w-4 bg-text-muted/70' : 'w-1 bg-text-faint/40']}></span>
        ))}
      </div>
      <div class="aspect-video w-full md:max-w-[896px] mx-auto mt-3">
        <iframe id="top-player-iframe"
          src={`https://www.youtube.com/embed/${videos[0].id}?rel=0`}
          title={videos[0].title}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen class="w-full h-full"></iframe>
      </div>
    </div>

    <!-- Music -->
    <div id="music" class="scroll-mt-[72px] md:scroll-mt-[86px] bg-[#131110] rounded-sm p-5 border border-white/[0.04]">
      <h2 class="font-mincho text-sm font-light tracking-[0.35em] text-text-primary mb-4">Music</h2>
      <iframe
        src="https://open.spotify.com/embed/artist/6cgNohFINOQDxktASQzmQy?utm_source=generator&theme=0"
        width="100%"
        height="352"
        frameborder="0"
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        loading="lazy"
        class="rounded-sm"
      ></iframe>
      <div class="flex items-center gap-5 mt-4 pt-4 border-t border-white/[0.04]">
        <a href="https://open.spotify.com/intl-ja/artist/6cgNohFINOQDxktASQzmQy" target="_blank" rel="noopener" class="hover:opacity-70 transition-opacity duration-300" aria-label="Spotify">
          <img src="https://www.google.com/s2/favicons?domain=spotify.com&sz=32" alt="Spotify" class="w-5 h-5" />
        </a>
        <a href="https://music.apple.com/us/artist/rinne-tao/1863623820" target="_blank" rel="noopener" class="hover:opacity-70 transition-opacity duration-300" aria-label="Apple Music">
          <img src="https://www.google.com/s2/favicons?domain=music.apple.com&sz=32" alt="Apple Music" class="w-5 h-5" />
        </a>
        <p class="text-text-faint text-[10px] font-light tracking-[0.15em] font-gothic">各種ストリーミングで配信中 <br /> — <span class="text-text-muted">"RInne Tao"</span> で検索</p>
      </div>
    </div>

    <!-- 依頼 -->
    <div class="bg-[#130f0e] rounded-sm p-5 border border-white/[0.04]">
      <h2 class="font-mincho text-sm font-light tracking-[0.35em] text-text-primary pb-3 mb-4 border-b border-white/15">お仕事のご依頼について</h2>
      <p class="text-text-muted text-[12px] font-light leading-[2] font-gothic mb-5">
        輪廻タヲは、音楽 / イラスト / 動画 / Webサイト制作に関するご依頼を募集しています。<br />詳細はこちら。
      </p>
      <a href="/commission" class="block text-center px-5 py-3 bg-white text-[#1a1a1a] text-[11px] font-sans-jp font-bold tracking-[0.15em] hover:bg-white/85 transition-all duration-300">
        お問合せ・お仕事のご依頼はこちら
      </a>
    </div>

  </div>

</Layout>

<script>
  // ===== Hero スライドショー =====
  const heroTrack = document.getElementById('hero-track') as HTMLElement;
  const heroSlideCount = document.querySelectorAll('.hero-slide').length;
  const heroDots = document.querySelectorAll<HTMLButtonElement>('.hero-dot');
  let heroIndex = 0;
  let heroTimer: ReturnType<typeof setInterval>;

  function renderTrack(instant = false) {
    heroTrack.style.transition = instant ? 'none' : 'transform 500ms ease-out';
    heroTrack.style.transform = `translateX(-${heroIndex * 100}%)`;
  }

  function goTo(rawIndex: number) {
    if (heroSlideCount === 0) return;
    const prevIndex = heroIndex;
    const newIndex = (rawIndex + heroSlideCount) % heroSlideCount;
    const isWrap = (prevIndex === heroSlideCount - 1 && newIndex === 0) || (prevIndex === 0 && newIndex === heroSlideCount - 1);
    heroDots[prevIndex]?.classList.remove('w-6', 'bg-text-muted/70');
    heroDots[prevIndex]?.classList.add('w-2', 'bg-text-faint/50');
    heroIndex = newIndex;
    heroDots[heroIndex]?.classList.remove('w-2', 'bg-text-faint/50');
    heroDots[heroIndex]?.classList.add('w-6', 'bg-text-muted/70');
    renderTrack(isWrap);
  }

  function startTimer() {
    heroTimer = setInterval(() => goTo(heroIndex + 1), 6000);
  }

  heroDots.forEach((dot, i) => {
    dot.addEventListener('click', () => { clearInterval(heroTimer); goTo(i); startTimer(); });
  });

  document.getElementById('hero-prev')?.addEventListener('click', () => { clearInterval(heroTimer); goTo(heroIndex - 1); startTimer(); });
  document.getElementById('hero-next')?.addEventListener('click', () => { clearInterval(heroTimer); goTo(heroIndex + 1); startTimer(); });

  startTimer();

  // ===== Hero スワイプ（指の動きに追従）=====
  const heroSwipeArea = document.getElementById('hero-swipe-area');
  let dragStartX = 0;
  let dragStartY = 0;
  let dragDeltaX = 0;
  let isDragging = false;
  let heroAreaWidth = 0;

  heroSwipeArea?.addEventListener('touchstart', (e) => {
    isDragging = true;
    dragStartX = e.touches[0].clientX;
    dragStartY = e.touches[0].clientY;
    dragDeltaX = 0;
    heroAreaWidth = heroSwipeArea.clientWidth;
    clearInterval(heroTimer);
    heroTrack.style.transition = 'none';
  }, { passive: true });

  heroSwipeArea?.addEventListener('touchmove', (e) => {
    if (!isDragging) return;
    const dx = e.touches[0].clientX - dragStartX;
    const dy = e.touches[0].clientY - dragStartY;
    if (Math.abs(dy) > Math.abs(dx)) return;
    const atStart = heroIndex === 0 && dx > 0;
    const atEnd = heroIndex === heroSlideCount - 1 && dx < 0;
    dragDeltaX = (atStart || atEnd) ? dx / 3 : dx;
    heroTrack.style.transform = `translateX(calc(-${heroIndex * 100}% + ${dragDeltaX}px))`;
  }, { passive: true });

  heroSwipeArea?.addEventListener('touchend', () => {
    if (!isDragging) return;
    isDragging = false;
    const threshold = heroAreaWidth * 0.15;
    if (Math.abs(dragDeltaX) > threshold) {
      goTo(heroIndex + (dragDeltaX < 0 ? 1 : -1));
    } else {
      renderTrack();
    }
    startTimer();
  }, { passive: true });

  // ===== Video スライダー =====
  const iframe = document.getElementById('top-player-iframe') as HTMLIFrameElement;
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.top-thumb');
  const thumbDots = document.querySelectorAll<HTMLSpanElement>('#top-thumb-dots [data-dot]');
  let current = 0;

  function select(index: number) {
    const btn = thumbs[index];
    if (!btn) return;
    iframe.src = `https://www.youtube.com/embed/${btn.dataset.id}?rel=0&autoplay=1`;
    thumbs.forEach((b, i) => {
      b.classList.toggle('ring-1', i === index);
      b.classList.toggle('ring-white/30', i === index);
      b.classList.toggle('opacity-40', i !== index);
    });
    thumbDots.forEach((d, i) => {
      d.classList.toggle('w-4', i === index);
      d.classList.toggle('bg-text-muted/70', i === index);
      d.classList.toggle('w-1', i !== index);
      d.classList.toggle('bg-text-faint/40', i !== index);
    });
    current = index;
    btn.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
  }

  thumbs.forEach((btn, i) => btn.addEventListener('click', () => select(i)));
  document.getElementById('top-prev')?.addEventListener('click', () => select((current - 1 + thumbs.length) % thumbs.length));
  document.getElementById('top-next')?.addEventListener('click', () => select((current + 1) % thumbs.length));
</script>
