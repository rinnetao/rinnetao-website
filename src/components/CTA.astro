---
interface Props {
  text?: string;
  label?: string;
  href?: string;
}

const {
  text = 'この記事が面白いと思ったら、Xのフォローお願いします☯',
  label = '@TaoRInne をフォローする',
  href = 'https://x.com/TaoRInne',
} = Astro.props;
---

<div class="not-prose my-10 border border-accent-line px-6 py-8 text-center">
  <p class="text-text-muted text-[13px] font-light leading-relaxed mb-4">{text}</p>
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-block px-6 py-[10px] bg-white !text-[#1a1a1a] !no-underline text-[11px] font-sans-jp font-bold tracking-[0.15em] hover:bg-white/85 transition-all duration-300"
  >
    {label}
  </a>
</div>
